---
hvy_version: 0.1
template: true
title: Resume Template
component_defs:
  - name: history-record
    baseType: expandable
    description: Expandable resume history record
    schema:
      component: history-record
      css: "margin: 0.35rem 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        - text: ""
          schema:
            component: table
            css: "margin: 0;"
            tableColumns: "YEAR, ORGANIZATION, TITLE"
            tableShowHeader: false
            tableRows:
              - cells:
                  - "{{history_year}}"
                  - "{{history_organization}}"
                  - "{{history_title}}"
      expandableContentBlocks:
        - text: "### {{history_title}}"
          schema:
            component: text
            css: "margin: 0 0 0.35rem;"
        - text: ""
          schema:
            component: grid
            css: "margin: 0.35rem 0;"
            gridColumns: 2
            gridItems:
              - id: history-location
                column: left
                block:
                  text: "{{history_location}}"
                  schema:
                    component: text
                    css: "margin: 0;"
              - id: history-date-range
                column: right
                block:
                  text: "{{history_date_range}}"
                  schema:
                    component: text
                    css: "margin: 0; text-align: right;"
        - text: "{{history_role_title}}"
          schema:
            component: text
            css: "margin: 0.35rem 0; font-weight: 700;"
        - text: "{{history_description}}"
          schema:
            component: text
            css: "margin: 0.35rem 0;"
        - text: "#### Accomplishments"
          schema:
            component: text
            css: "margin: 0.6rem 0 0.25rem;"
        - text: ""
          schema:
            component: component-list
            componentListComponent: text
            css: "margin: 0;"
            componentListBlocks:
              - text: "{{history_accomplishments.0}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{history_accomplishments.1}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{history_accomplishments.2}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
        - text: ""
          schema:
            component: skills-and-tools-tech-list
            css: "margin: 0.6rem 0 0;"
            gridColumns: 2
            gridItems:
              - id: history-skills
                column: left
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Relevant Skills"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{history_skills.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{history_skills.1}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{history_skills.2}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
              - id: history-tools-technologies
                column: right
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Tools and Technologies"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{history_tools_technologies.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{history_tools_technologies.1}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{history_tools_technologies.2}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Two-column skills and tools list
    schema:
      component: skills-and-tools-tech-list
      css: "margin: 0.6rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          column: left
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: text
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
                - text: "{{relevant_skills.0}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
                - text: "{{relevant_skills.1}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
                - text: "{{relevant_skills.2}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
        - id: tools-technologies
          column: right
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: text
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
                - text: "{{tools_technologies.0}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
                - text: "{{tools_technologies.1}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
                - text: "{{tools_technologies.2}}"
                  schema:
                    component: text
                    css: "margin: 0.25rem 0;"
  - name: education-record
    baseType: expandable
    description: Expandable education record
    schema:
      component: education-record
      css: "margin: 0.35rem 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        - text: ""
          schema:
            component: table
            css: "margin: 0;"
            tableColumns: "DEGREE, INSTITUTION, LOCATION"
            tableShowHeader: false
            tableRows:
              - cells:
                  - "{{education_degree}}"
                  - "{{education_institution}}"
                  - "{{education_location}}"
      expandableContentBlocks:
        - text: "### {{education_degree}}"
          schema:
            component: text
            css: "margin: 0 0 0.35rem;"
        - text: ""
          schema:
            component: grid
            css: "margin: 0.35rem 0;"
            gridColumns: 2
            gridItems:
              - id: education-institution-details
                column: left
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "{{education_institution}}"
                        schema:
                          component: text
                          css: "margin: 0;"
                      - text: "{{education_location}}"
                        schema:
                          component: text
                          css: "margin: 0.15rem 0 0;"
                      - text: "{{education_gpa}}"
                        schema:
                          component: text
                          css: "margin: 0.15rem 0 0;"
              - id: education-date-range
                column: right
                block:
                  text: "{{education_date_range}}"
                  schema:
                    component: text
                    css: "margin: 0; text-align: right;"
        - text: "{{education_description}}"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: skills-and-tools-tech-list
            css: "margin: 0.6rem 0 0;"
            gridColumns: 2
            gridItems:
              - id: education-relevant-skills
                column: left
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Relevant Skills"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{education_relevant_skills.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
              - id: education-tools-technologies
                column: right
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Tools and Technologies"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{education_tools_technologies.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{education_tools_technologies.1}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
        - text: "#### Classes"
          schema:
            component: text
            css: "margin: 0.6rem 0 0.25rem;"
        - text: ""
          schema:
            component: component-list
            componentListComponent: text
            css: "margin: 0;"
            componentListBlocks:
              - text: "{{education_classes.0}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{education_classes.1}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{education_classes.2}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{education_classes.3}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{education_classes.4}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
              - text: "{{education_classes.5}}"
                schema:
                  component: text
                  css: "margin: 0.25rem 0;"
  - name: project-record
    baseType: expandable
    description: Expandable project record
    schema:
      component: project-record
      css: "margin: 0.35rem 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        - text: ""
          schema:
            component: table
            css: "margin: 0;"
            tableColumns: "PROJECT, DATE"
            tableShowHeader: false
            tableRows:
              - cells:
                  - "{{project_name}}"
                  - "{{project_date_range}}"
      expandableContentBlocks:
        - text: ""
          schema:
            component: grid
            css: "margin: 0 0 0.35rem;"
            gridColumns: 2
            gridItems:
              - id: project-title
                column: left
                block:
                  text: "### {{project_name}}"
                  schema:
                    component: text
                    css: "margin: 0;"
              - id: project-date-range
                column: right
                block:
                  text: "{{project_date_range}}"
                  schema:
                    component: text
                    css: "margin: 0; text-align: right;"
        - text: "{{project_description}}"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: "[Visit webpage]({{project_url}}) ({{project_url_label}})"
          schema:
            component: text
            css: "margin: 0.35rem 0;"
        - text: ""
          schema:
            component: skills-and-tools-tech-list
            css: "margin: 0.6rem 0 0;"
            gridColumns: 2
            gridItems:
              - id: project-relevant-skills
                column: left
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Relevant Skills"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{project_relevant_skills.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{project_relevant_skills.1}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
              - id: project-tools-technologies
                column: right
                block:
                  text: ""
                  schema:
                    component: component-list
                    componentListComponent: text
                    css: "margin: 0;"
                    componentListBlocks:
                      - text: "#### Tools and Technologies"
                        schema:
                          component: text
                          css: "margin: 0 0 0.25rem;"
                      - text: "{{project_tools_technologies.0}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{project_tools_technologies.1}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{project_tools_technologies.2}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
                      - text: "{{project_tools_technologies.3}}"
                        schema:
                          component: text
                          css: "margin: 0.25rem 0;"
---

<!--hvy: {"id":"header","lock":true}-->
#! Info

<!--hvy:text {"css":"margin-bottom: 0;","align":"center"}-->
# Name

<!--hvy:text {"css":"margin-top: 0;","align":"center"}-->
[pronunciation]

<!--hvy:text {"css":"margin: 0.5rem 0; margin-top: 1rem;","align":"center"}-->
Title

<!--hvy: {"id":"summary","lock":true}-->
#! Summary

<!--hvy:expandable {"css":"margin: 0.5rem 0;","expandableAlwaysShowStub":true,"expandableExpanded":false,"lock":true}-->

<!--hvy:expandable:0 {"component":"text","css":"margin-bottom: 0;","lock":true}-->
## Summary

<!--hvy:expandable:0 {"component":"text","css":"margin-top: 0;","lock":true}-->
{{summary}}

<!--hvy:expandable:1 {"component":"text","css":"margin: 0;","lock":true}-->
- {{summary_highlights.0}}
- {{summary_highlights.1}}
- {{summary_highlights.2}}

<!--hvy: {"id":"locations","lock":true}-->
#! Locations

<!--hvy:text {"css":"margin: 0.5rem 0;","lock":true}-->
**Location:** {{location}}

<!--hvy:text {"css":"margin: 0.5rem 0;","lock":true}-->
**Target Location(s):** {{target_locations}}

<!--hvy: {"id":"top-skills-tools-technologies","lock":true}-->
#! Top Skills, Tools, and Technologies

<!--hvy:grid {"css":"margin: 0.5rem 0; gap: 0.75rem;","gridColumns":2,"lock":true}-->

<!--hvy:grid:0 {"id":"top-skills","column":"left","component":"component-list","componentListComponent":"text","css":"margin: 0;"}-->

<!--hvy:component-list:0 {"component":"text","css":"margin: 0 0 0.35rem;"}-->
## Skills

<!--hvy:component-list:1 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_skills.0}}](#skill-software-engineering)

<!--hvy:component-list:2 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_skills.1}}](#skill-library-development)

<!--hvy:component-list:3 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_skills.2}}](#skill-llm-prompt-engineering)

<!--hvy:grid:1 {"id":"top-tools-technologies","column":"right","component":"component-list","componentListComponent":"text","css":"margin: 0;"}-->

<!--hvy:component-list:0 {"component":"text","css":"margin: 0 0 0.35rem;"}-->
## Tools & Technologies

<!--hvy:component-list:1 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_tools_technologies.0}}](#tool-typescript)

<!--hvy:component-list:2 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_tools_technologies.1}}](#tool-python)

<!--hvy:component-list:3 {"component":"text","css":"margin: 0.35rem 0; padding: 0.55rem 0.65rem; border: 1px solid #d7e0e8; border-radius: 8px; box-shadow: 0 2px 8px rgba(41, 67, 82, 0.12); background: #fff;"}-->
[{{top_tools_technologies.2}}](#tool-developer-containers)

<!--hvy: {"id":"skills","lock":true,"expanded":false}-->
#! Skills

<!--hvy:text {"css":"margin: 0.5rem 0;"}-->
# Skills

<!--hvy:expandable {"id":"skill-software-engineering","css":"margin: 0.35rem 0;","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

<!--hvy:expandable:0 {"component":"text","css":"margin: 0;"}-->
Software Engineering

