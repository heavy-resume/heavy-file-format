<!--hvy: {"id":"template-maintenance","editorOnly":true,"lock":true,"contained":true,"description":"Template maintenance scripts"}-->
#! Template Maintenance

 <!--hvy:plugin {"id":"sync-reciprocal-xrefs","editorOnly":true,"plugin":"hvy.scripting","pluginConfig":{"version":"0.1","maxLines":200000}}-->
  SOURCE_TAG = "reciprocal-xref-source"
  GENERATED_TAG = "reciprocal-xref-generated"
  TARGET_TAGS = ["skill", "tool"]

  def xref_component_for_source(source):
      if source.component.endswith("-record"):
          return source.component[:-len("-record")] + "-xref-card"
      return "xref-card"

  def is_generated(component):
      return component.has_tag(GENERATED_TAG)

  def is_target_record(record):
      if not record.component.endswith("-record"):
          return False
      for tag in TARGET_TAGS:
          if record.has_tag(tag):
              return True
      return False

  changed_xrefs = []
  for xref in doc.tool.get_updated_components("xref"):
      if not is_generated(xref):
          changed_xrefs.append(xref)

  if not changed_xrefs:
      return

  # Targets are the real skill/tool records where reciprocal cards are written.
  targets = {}
  for record in doc.tool.get_components():
      if is_target_record(record):
          targets[record.id] = record

  # Groups collect the current real xrefs by target record and source section.
  groups = {}
  for target_id in targets:
      groups[target_id] = {}

  # Rebuild from current xrefs so changed, added, and removed xrefs all produce
  # the same final reciprocal state.
  for xref in doc.tool.get_components("xref"):
      if is_generated(xref):
          continue
      source_section = xref.get_parent_by_tag(SOURCE_TAG)
      target_id = str(xref.get("xrefTarget") or "")
      if not source_section or target_id not in targets:
          continue
      source = xref.get_ancestor_record() or source_section
      group_key = source.section_id
      if group_key not in groups[target_id]:
          groups[target_id][group_key] = []
      seen = False
      for item in groups[target_id][group_key]:
          if item.id == source.id:
              seen = True
      if not seen:
          groups[target_id][group_key].append(source)

  for target_id in targets:
      target = targets[target_id]
      target.remove_children_by_tag(GENERATED_TAG)
      for group_key in groups[target_id]:
          sources = groups[target_id][group_key]
          if not sources:
              continue
          first = sources[0]
          heading = target.append_child("text")
          heading.set("tags", GENERATED_TAG)
          heading.set("css", "margin: 0;")
          heading.set("text", "^detail-heading^ #### " + first.section_title)
          card_component = xref_component_for_source(first)
          cards = target.append_child("component-list")
          cards.set("tags", GENERATED_TAG)
          cards.set("css", "margin: 0;")
          cards.set("componentListComponent", card_component)
          cards.set("componentListItemLabel", "reference")
          for source in sources:
              card = cards.append_child(card_component, None, "", "component-list")
              card.set("tags", GENERATED_TAG)
              card.set("xrefTitle", source.get("xrefTitle") or source.first_table_cell(0) or source.id)
              card.set("xrefDetail", source.get("xrefDetail") or source.first_table_cell(1) or "")
              card.set("xrefTarget", source.id)
