---
hvy_version: 0.1
title: Resume Example
theme:
  colors:
    --hvy-bg: "#0f1720"
    --hvy-bg-alt: "#161b22"
    --hvy-surface: "#17222d"
    --hvy-surface-alt: "#1c2733"
    --hvy-surface-tint: "#1f3448"
    --hvy-text: "#e7eef5"
    --hvy-text-alt: "#a3adbf"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#7db3d0"
    --hvy-accent-1-alt: "#5a8da8"
    --hvy-accent-1-text: "#fcfcfc"
    --hvy-accent-2: "#6fb3c1"
    --hvy-accent-2-alt: "#2d5d68"
    --hvy-button-bg: "#2d6a8a"
    --hvy-button-text: "#ffffff"
    --hvy-link-color: "#7bc0e8"
    --hvy-highlight-1: "rgba(125, 179, 208, 0.20)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.25)"
    --hvy-border: "#2a3340"
    --hvy-border-alt: "#3d4756"
    --hvy-border-input: "#334152"
    --hvy-border-translucent: "rgba(42, 51, 64, 0.92)"
    --hvy-xref-card-bg: "rgba(255, 255, 255, 0.04)"
    --hvy-xref-card-hover-bg: "rgba(255, 255, 255, 0.08)"
    --hvy-table-header: "#1f2a37"
    --hvy-table-row-bg-1: "#17222d"
    --hvy-table-row-bg-2: "#1b2632"
    --hvy-icon-muted: "rgba(231, 238, 245, 0.33)"
    --hvy-shadow: "rgba(0, 0, 0, 0.20)"
    --hvy-shadow-md: "rgba(0, 0, 0, 0.30)"
    --hvy-shadow-lg: "rgba(0, 0, 0, 0.40)"
    --hvy-overlay: "rgba(0, 0, 0, 0.60)"
    --hvy-danger: "#c05050"
    --hvy-warning: "#d4a017"
    --hvy-warning-bg: "#2a2310"
    --hvy-warning-border: "#6b5200"
    --hvy-warning-accent: "#c79200"
    --hvy-success: "#4cae68"
    --hvy-success-bg: "#152b1e"
    --hvy-success-border: "#2e7a46"
component_defs:
  - name: history-record
    baseType: expandable
    description: Expandable resume history record
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;  margin-top: -1px;"
              tableColumns: "YEAR, ORGANIZATION, TITLE"
              tableShowHeader: false
              tableRows:
                - cells: ["", "", ""]
      expandableContentBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: text
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  column: left
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0;"
                - id: history-date-range
                  column: right
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
          - text: ""
            schema:
              component: text
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: ""
            schema:
              component: text
              css: "margin: 0.35rem 0;"
          - text: "#### Accomplishments"
            schema:
              component: text
              css: "margin: 0.5rem 0 0.25rem;"
          - text: ""
            schema:
              component: component-list
              componentListComponent: text
              css: "margin: 0;"
              componentListBlocks: []
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Two-column skills and tools list
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          column: left
          align: center
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: xref-card
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
        - id: tools-technologies
          column: right
          align: center
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: xref-card
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
  - name: education-record
    baseType: expandable
    description: Expandable education record
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: "DEGREE, INSTITUTION, LOCATION"
              tableShowHeader: false
              tableRows:
                - cells: ["", "", ""]
      expandableContentBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  column: left
                  block:
                    text: ""
                    schema:
                      component: component-list
                      componentListComponent: text
                      css: "margin: 0;"
                      componentListBlocks:
                        - text: ""
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Degree Title"
                - id: education-date-range
                  column: right
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Start Year – End Year"
          - text: ""
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
          - text: "#### Classes"
            schema:
              component: text
              css: "margin: 0.5rem 0 0.25rem;"
          - text: ""
            schema:
              component: component-list
              componentListComponent: text
              css: "margin: 0;"
              componentListBlocks: []
  - name: project-record
    baseType: expandable
    description: Expandable project record
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;  margin-top: -1px;"
              tableColumns: "PROJECT, DATE"
              tableShowHeader: false
              tableRows:
                - cells: ["", ""]
      expandableContentBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: project-title
                  column: left
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0;"
                - id: project-date-range
                  column: right
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
          - text: ""
            schema:
              component: text
              css: "margin: 0.5rem 0;"
          - text: ""
            schema:
              component: text
              css: "margin: 0.35rem 0;"
          - component: skills-and-tools-tech-list
  - name: skill-record-experience-section
    baseType: container
    description: Skill record experience section
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Experience"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-education-section
    baseType: container
    description: Skill record education section
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Education"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-projects-section
    baseType: container
    description: Skill record projects section
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Projects"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-section
    baseType: container
    description: Reusable skill record section with heading and repeatable entries
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: ""
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
            placeholder: "#### Section title"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: skill-record-entry
            componentListBlocks: []
  - name: skill-record
    baseType: expandable
    description: Skill record
    schema:
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        lock: true
        children:
          - text: ""
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Skill name"
      expandableContentBlocks:
        lock: false
        children:
          - text: "#### Description"
            schema:
              component: text
              css: "margin: 0.4rem 0 0.1rem;"
          - text: ""
            css: "margin-left: 0.5rem;"
            schema:
              component: text
              css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
              placeholder: "What is it?"
          - text: "#### Notes"
            schema:
              component: text
              css: "margin: 0.4rem 0 0.1rem;"
          - text: ""
            schema:
              component: text
              css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
              placeholder: "Notes"
          - component: skill-record-experience-section
          - component: skill-record-education-section
          - component: skill-record-projects-section
---

<!--hvy: {"id":"header","lock":true}-->
#! Info

 <!--hvy:text {"css":"margin-bottom: 0;","align":"center"}-->
  # Avery Hart

 <!--hvy:text {"css":"margin-top: 0;","align":"center"}-->
  [AY-vuh-ree HART]

 <!--hvy:text {"css":"margin: 0.5rem 0; margin-top: 1rem;","align":"center"}-->
  Senior Software Engineer

<!--hvy: {"id":"summary","lock":true}-->
#! Summary

 <!--hvy:expandable {"css":"margin: 0.5rem 0;","expandableAlwaysShowStub":true,"expandableExpanded":false,"lock":true}-->

  <!--hvy:expandable:stub {"lock":true}-->

   <!--hvy:text {"css":"margin-bottom: 0;"}-->
    ## Summary

  <!--hvy:expandable:stub {"lock":true}-->

   <!--hvy:text {"css":"margin-top: 0;"}-->
    Product-minded software engineer focused on developer tooling, AI workflows, and reusable systems that make complex products easier to ship and maintain.

  <!--hvy:expandable:content {"lock":true}-->

   <!--hvy:component-list {"componentListComponent":"text","css":"margin: 0;"}-->

    <!--hvy:component-list:0 {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Builds polished internal tools that reduce friction for engineers and product teams.

    <!--hvy:component-list:1 {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Comfortable moving between frontend UX, platform design, and AI-assisted workflows.

    <!--hvy:component-list:2 {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Enjoys turning messy, high-context problems into repeatable systems and clear documentation.

<!--hvy: {"id":"locations","lock":true}-->
#! Locations

 <!--hvy:text {"css":"margin: 0.5rem 0;","lock":true}-->
  **Location:** Seattle, WA

 <!--hvy:text {"css":"margin: 0.5rem 0;","lock":true}-->
  **Target Location(s):** Remote, Seattle, San Francisco

<!--hvy: {"id":"top-skills-tools-technologies","lock":true}-->
#! Top Skills, Tools, and Technologies

 <!--hvy:grid {"css":"margin: 0.5rem 0; gap: 0.75rem;","gridColumns":2,"lock":true}-->

  <!--hvy:grid:0 {"id":"top-skills","column":"left"}-->

   <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;","align":"center"}-->

    <!--hvy:component-list:0 {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem;"}-->
      ## Skills

    <!--hvy:component-list:1 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Software Engineering","xrefDetail":"Core strength","xrefTarget":"skill-software-engineering"}-->

    <!--hvy:component-list:2 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Library Development","xrefDetail":"Reusable systems","xrefTarget":"skill-library-development"}-->

    <!--hvy:component-list:3 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"LLM Prompt Engineering","xrefDetail":"Product workflow design","xrefTarget":"skill-llm-prompt-engineering"}-->

  <!--hvy:grid:1 {"id":"top-tools-technologies","column":"right"}-->

   <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;","align":"center"}-->

    <!--hvy:component-list:0 {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem;"}-->
      ## Tools & Technologies

    <!--hvy:component-list:1 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"TypeScript","xrefDetail":"Primary application language","xrefTarget":"tool-typescript"}-->

    <!--hvy:component-list:2 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Python","xrefDetail":"Automation and prototyping","xrefTarget":"tool-python"}-->

    <!--hvy:component-list:3 {}-->

     <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Developer Containers","xrefDetail":"Reproducible local environments","xrefTarget":"tool-developer-containers"}-->

<!--hvy: {"id":"skills","lock":true,"expanded":false,"location":"sidebar"}-->
#! Skills

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Skills

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"skill-record"}-->

  <!--hvy:component-list:0 {}-->

   <!--hvy:skill-record {"id":"skill-software-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Software Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Designing, building, and maintaining software systems with a focus on reliability, maintainability, and developer experience.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Notes

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Core strength. Approaches engineering as a systems discipline — prioritizing clear APIs, testable boundaries, and incremental delivery over clever solutions.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Experience

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

