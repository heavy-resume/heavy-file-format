---
hvy_version: 0.1
template: true
title: Resume Template
reader_max_width: 60rem
ai-context: >-
  This is a resume template. Use the top-skills-tools-technologies section for featured
  reference cards only; the skills and tools-technologies sidebar sections are the main
  reusable libraries for detailed skill/tool records. History, projects, and education
  each have a static table used only as the visible column header for the expandable
  record rows in the following component-list; keep them in reverse chronological order
  with newest entries first. History should use one
  expandable record per organization when roles are contiguous; put promotions, title
  changes, or adjacent date ranges at the same organization inside that single expanded
  record instead of creating duplicate organization rows. One project, publication,
  certification, degree, skill, or tool should usually be represented as one expandable
  reusable record. Local skills/tools lists inside history, project, publication,
  certification, and education records are supporting references and should not be treated as
  the main libraries.
section_defaults:
  css: "margin: 0.5rem 0;"
text_line_styles:
  panel-heading:
    label: Panel heading
    css: "margin: 0 0 0.25rem;"
  section-heading:
    label: Section heading
    css: "margin: 0.5rem 0 0.25rem;"
  detail-heading:
    label: Detail heading
    css: "margin: 0.4rem 0 0.1rem;"
  detail-body:
    label: Detail body
    css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
theme:
  colors:
    --hvy-bg: "#f5f9ff"
    --hvy-bg-alt: "#eef3fa"
    --hvy-surface: "#ffffff"
    --hvy-surface-alt: "#f9fcff"
    --hvy-surface-tint: "#d9eaf4"
    --hvy-text: "#1a2530"
    --hvy-text-alt: "#4b5c67"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#2c5e78"
    --hvy-accent-1-alt: "#1f4f63"
    --hvy-accent-1-text: "#000000"
    --hvy-accent-2: "#325f6e"
    --hvy-accent-2-alt: "#244355"
    --hvy-button-bg: "#4a8fab"
    --hvy-button-text: "#000000"
    --hvy-link-color: "#162f3d"
    --hvy-highlight-1: "rgba(31, 122, 140, 0.15)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.35)"
    --hvy-border: "#ced9e2"
    --hvy-border-alt: "#b8c8d3"
    --hvy-border-input: "#c8d4dd"
    --hvy-border-translucent: "rgba(206, 217, 226, 0.92)"
    --hvy-ghost-border: "rgba(107, 143, 160, 0.38)"
    --hvy-xref-card-bg: "#f3f5f8"
    --hvy-xref-card-hover-bg: "#eef8fb"
    --hvy-table-header: "#e5e7eb"
    --hvy-table-row-bg-1: "#ffffff"
    --hvy-table-row-bg-2: "#f9fafb"
    --hvy-icon-muted: "rgba(26, 37, 48, 0.33)"
    --hvy-shadow: "rgba(39, 70, 91, 0.08)"
    --hvy-shadow-md: "rgba(39, 70, 91, 0.12)"
    --hvy-shadow-lg: "rgba(39, 70, 91, 0.14)"
    --hvy-overlay: "rgba(15, 23, 32, 0.4)"
    --hvy-danger: "#a64040"
    --hvy-warning: "#c79200"
    --hvy-warning-bg: "#fff3de"
    --hvy-warning-border: "#ebca8d"
    --hvy-warning-text: "#e2b100"
    --hvy-success: "#1c6231"
    --hvy-success-bg: "#e7f9ee"
    --hvy-success-border: "#95d8a9"
section_defs:
  - name: Projects
    key: resume-projects
    template:
      id: projects
      title: Projects
      level: 1
      lock: true
      description: Project portfolio
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Projects"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PROJECT
              - DATES
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Project table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: project-record
            componentListItemLabel: project
            tags: project
            componentListBlocks: []
      children: []
  - name: Publications
    key: resume-publications
    template:
      id: publications
      title: Publications
      level: 1
      lock: true
      description: Publications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Publications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PUBLICATION
              - PUBLISHER
              - DATE
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Publication table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: publication-record
            componentListItemLabel: publication
            tags: publication
            componentListBlocks: []
      children: []
  - name: Certifications
    key: resume-certifications
    template:
      id: certifications
      title: Certifications
      level: 1
      lock: true
      description: Certifications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Certifications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - "<!--hvy:alt {\"compact\":\"CERT\"}-->CERTIFICATION<!--/hvy:alt-->"
              - ISSUER
              - OBTAINED
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Certification table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: certification-record
            componentListItemLabel: certification
            tags: certification
            componentListBlocks: []
      children: []
  - name: Resume Section
    key: resume-section
    repeatable: true
    template:
      title: Resume Section
      level: 1
      lock: true
      description: Additional resume section
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Resume Section"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
            placeholder: "# Section title"
        - text: ""
          schema:
            component: text
            css: "margin: 0;"
            placeholder: "Add section details, records, and any relevant skill or tool references."
      children: []
component_defs:
  - name: skill-xref-card
    baseType: xref-card
    description: Skill reference
    schema:
      xrefTargetTagFilter: skill
      css: "margin: 0.25rem 0;"
  - name: tool-tech-xref-card
    baseType: xref-card
    description: Tool / technology reference
    schema:
      xrefTargetTagFilter: tool
      css: "margin: 0.25rem 0;"
  - name: history-xref-card
    baseType: xref-card
    description: Work history reference
    schema:
      xrefTargetTagFilter: history
      css: "margin: 0.25rem 0;"
  - name: education-xref-card
    baseType: xref-card
    description: Education reference
    schema:
      xrefTargetTagFilter: education
      css: "margin: 0.25rem 0;"
  - name: certification-xref-card
    baseType: xref-card
    description: Certification reference
    schema:
      xrefTargetTagFilter: certification
      css: "margin: 0.25rem 0;"
  - name: publication-xref-card
    baseType: xref-card
    description: Publication reference
    schema:
      xrefTargetTagFilter: publication
      css: "margin: 0.25rem 0;"
  - name: project-xref-card
    baseType: xref-card
    description: Project reference
    schema:
      xrefTargetTagFilter: project
      css: "margin: 0.25rem 0;"
  - name: history-record
    baseType: expandable
    description: Work history organization entry
    templateVariables:
      role:
        label: Role / Title
      years:
        label: Year(s)
    schema:
      tags: history
      xrefTitle: "{% role %}"
      xrefDetail: "{% organization %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["TITLE", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "YEAR(S)"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% role %}", "{% organization %}", "{% years %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: "{% organization %}"
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: "{% location %}"
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: "{% role %}"
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: "{% description | block %}"
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "^section-heading^ #### Accomplishments"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: accomplishments
              css: "margin: 0;"
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Related skills and tools
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: skill-xref-card
                    componentListItemLabel: skill reference
                    css: "margin: 0;"
                    componentListBlocks: []
        - id: tools-technologies
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: tool-tech-xref-card
                    componentListItemLabel: tool / tech reference
                    css: "margin: 0;"
                    componentListBlocks: []
  - name: education-record
    baseType: expandable
    description: Education entry
    templateVariables:
      institution:
        label: School / University
      date_range:
        label: Date range
      gpa:
        label: GPA
    schema:
      tags: education
      xrefTitle: "{% degree %}"
      xrefDetail: "{% institution %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children: []
      expandableContentBlocks:
        children:
          - text: "^section-heading^ ### {% degree %}"
            schema:
              component: text
              css: "margin: 0 0 0.25rem;"
              placeholder: "Degree"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "{% institution %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "School / University"
                        - text: "{% location %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Location"
                        - text: "{% gpa %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "GPA"
                - id: education-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Start Year - End Year"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
          - text: "^section-heading^ #### Classes"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: classes
              css: "margin: 0;"
  - name: certification-record
    baseType: expandable
    description: Certification entry
    templateVariables:
      name:
        label: Certification name
      obtained_from:
        label: Obtained from
      obtained_month:
        label: Obtained month
      obtained_year:
        label: Obtained year
    schema:
      tags: certification
      xrefTitle: "{% name %}"
      xrefDetail: "{% obtained_from %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["<!--hvy:alt {\"compact\":\"CERT\"}-->CERTIFICATION<!--/hvy:alt-->", "ISSUER", "OBTAINED"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% name %}", "{% obtained_from %}", "{% obtained_month %}/{% obtained_year %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: certification-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "^section-heading^ ### {% name %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Certification name"
                        - text: "{% obtained_from %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "Obtained from"
                - id: certification-obtained-date
                  block:
                    text: "{% obtained_month %}/{% obtained_year %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Obtained month / year"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
  - name: publication-record
    baseType: expandable
    description: Publication entry
    templateVariables:
      name:
        label: Publication name
      authors:
        label: Authors
      publisher:
        label: Publisher
      date:
        label: Publication date
      employer_short_name:
        label: Employer short name
      url:
        label: Publication URL
    schema:
      tags: publication
      xrefTitle: "{% name %}"
      xrefDetail: "{% publisher %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["PUBLICATION", "PUBLISHER", "DATE"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% name %}", "{% publisher %}", "{% date %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: publication-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "^section-heading^ ### {% name %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Publication name"
                        - text: "{% authors %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Authors"
                        - text: "{% publisher %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Publisher"
                        - text: "{% employer_short_name %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "Employer short name"
                - id: publication-date
                  block:
                    text: "{% date %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Publication date"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - text: "{% url %}"
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Publication URL"
          - component: skills-and-tools-tech-list
  - name: project-record
    baseType: expandable
    description: Project entry
    templateVariables:
      project:
        label: Project name
      date_range:
        label: Date range
      link:
        label: Project link
    schema:
      tags: project
      xrefTitle: "{% project %}"
      xrefDetail: "{% date_range %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["PROJECT", "DATES"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% project %}", "{% date_range %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: project-title
                  block:
                    text: "{% project %}"
                    schema:
                      component: text
                      css: "margin: 0;"
                      placeholder: "Project name"
                - id: project-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Date range"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Project description"
          - text: "{% link %}"
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Project link"
          - component: skills-and-tools-tech-list
  - name: skill-record-experience-section
    baseType: container
    description: Related work history
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Experience"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: history-xref-card
            componentListItemLabel: history reference
            componentListBlocks: []
  - name: skill-record-education-section
    baseType: container
    description: Related education
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Education"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: education-xref-card
            componentListItemLabel: education reference
            componentListBlocks: []
  - name: skill-record-projects-section
    baseType: container
    description: Related projects
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Projects"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: project-xref-card
            componentListItemLabel: project reference
            componentListBlocks: []
  - name: skill-record-section
    baseType: container
    description: Skill detail group
    templateVariables:
      section_title:
        label: Section title
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ {% section_title %}"
          schema:
            component: text
            css: "margin: 0;"
            placeholder: "#### Section title"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: skill-record-entry
            componentListItemLabel: detail
            componentListBlocks: []
  - name: skill-record
    baseType: expandable
    description: Skill details
    templateVariables:
      skill:
        label: Skill
      description:
        label: Description
        generator: dev.hvy.resume.skill-description
        generatorLabel: Generate
    schema:
      xrefTitle: "{% skill %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        children:
          - text: "### {% skill %}"
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "### Skill name"
      expandableContentBlocks:
        lock: false
        css: "padding: 0.5rem;"
        children:
          - text: |-
              ^detail-heading^ #### Description
              ^detail-body^ {% description | block %}
              ^detail-heading^ #### Notes
              ^detail-body^ {% notes | block %}
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Description and notes"
  - name: tool-tech-record
    baseType: expandable
    description: Tool / technology details
    templateVariables:
      tool_technology:
        label: Tool / Technology
      description:
        label: Description
        generator: dev.hvy.resume.tool-description
        generatorLabel: Generate
    schema:
      xrefTitle: "{% tool_technology %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        children:
          - text: "### {% tool_technology %}"
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "### Tool / technology name"
      expandableContentBlocks:
        lock: false
        css: "padding: 0.5rem;"
        children:
          - text: |-
              ^detail-heading^ #### Description
              ^detail-body^ {% description | block %}
              ^detail-heading^ #### Notes
              ^detail-body^ {% notes | block %}
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Description and notes"
---

<!--hvy: {"id":"header","lock":true,"contained":false,"description":"Resume identity header","hideIfUnmodified":true,"priority":true}-->
#! Info

 <!--hvy:text {"id":"resume-name","css":"margin-bottom: 0;","align":"center","fillIn":true}-->
  # <!-- value {"placeholder":"Name"} -->

