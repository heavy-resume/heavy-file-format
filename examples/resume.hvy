---
hvy_version: 0.1
title: Resume Example
reader_max_width: 60rem
ai-context: >-
  This is a resume document. Use the top-skills-tools-technologies section for featured
  reference cards only; the skills, tools-technologies, and languages sidebar sections
  are the main reusable libraries for detailed reference records. History and education
  have body sections with structured component-lists for expandable record rows.
  Projects, publications, awards, and certifications are section templates
  that should be added only when source-backed content exists. Keep dated main-section
  records in reverse chronological order with newest entries first. History should use
  one expandable record per organization when roles are contiguous; put promotions,
  title changes, or adjacent date ranges at the same organization inside that single
  expanded record instead of creating duplicate organization rows. Use the tableform
  History section flavor for longer histories with more items, and the linear History
  section flavor for shorter histories. One project,
  publication, certification, degree, skill, or tool should usually be represented as
  one expandable reusable record. Local skills/tools lists inside history, project,
  publication, certification, award, and education records are supporting references
  and should not be treated as the main libraries.
ai-import-guidance: >-
  During resume import, map source-backed awards into the Awards section
  template even when the source mentions awards inside work history, projects,
  education, summaries, or other prose instead of providing an explicit Awards heading.
  Treat those mentions as award-record items when they identify a distinct award,
  recognition, honor, finalist placement, prize, or equivalent accolade. Do not create
  Awards when the source has no distinct source-backed award-like item.
  Any sort of job goes under professional history.
  A skill is something you do. For example, programming.
  A tool / technology is something you use and would have experience with. Such as
  a programming language, machinery, etc.
export_prompt_templates:
  - id: tailor-resume-export
    label: Tailor resume for prompt
    description: Select and arrange resume content for pasted export criteria.
    prompt: |-
      Plan a PDF export of this document for the following criteria.

      {% target_context | block %}
    variables:
      target_context:
        label: Target context
        placeholder: Paste a job description, audience note, grant criteria, project brief, or other export criteria.
        helpText: Used only to plan the PDF export.
        type: block
        required: true
section_defaults:
  css: "margin: 0.5rem 0;"
text_line_styles:
  panel-heading:
    label: Panel heading
    css: "margin: 0 0 0.25rem;"
  section-heading:
    label: Section heading
    css: "margin: 0.5rem 0 0.25rem;"
  detail-heading:
    label: Detail heading
    css: "margin: 0.4rem 0 0.1rem;"
  detail-body:
    label: Detail body
    css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
theme:
  colors:
    --hvy-bg: "#0f1720"
    --hvy-bg-alt: "#161b22"
    --hvy-surface: "#17222d"
    --hvy-surface-alt: "#1c2733"
    --hvy-surface-tint: "#1f3448"
    --hvy-text: "#e7eef5"
    --hvy-text-alt: "#a3adbf"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#7db3d0"
    --hvy-accent-1-alt: "#5a8da8"
    --hvy-accent-1-text: "#fcfcfc"
    --hvy-accent-2: "#6fb3c1"
    --hvy-accent-2-alt: "#2d5d68"
    --hvy-button-bg: "#2d6a8a"
    --hvy-button-text: "#ffffff"
    --hvy-link-color: "#7bc0e8"
    --hvy-highlight-1: "rgba(125, 179, 208, 0.20)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.25)"
    --hvy-border: "#2a3340"
    --hvy-border-alt: "#3d4756"
    --hvy-border-input: "#334152"
    --hvy-border-translucent: "rgba(42, 51, 64, 0.92)"
    --hvy-ghost-border: "rgba(231, 238, 245, 0.22)"
    --hvy-xref-card-bg: "rgba(255, 255, 255, 0.04)"
    --hvy-xref-card-hover-bg: "rgba(255, 255, 255, 0.08)"
    --hvy-table-header: "#1f2a37"
    --hvy-table-row-bg-1: "#17222d"
    --hvy-table-row-bg-2: "#1c2835"
    --hvy-icon-muted: "rgba(231, 238, 245, 0.33)"
    --hvy-shadow: "rgba(0, 0, 0, 0.20)"
    --hvy-shadow-md: "rgba(0, 0, 0, 0.30)"
    --hvy-shadow-lg: "rgba(0, 0, 0, 0.40)"
    --hvy-overlay: "rgba(0, 0, 0, 0.60)"
    --hvy-danger: "#c05050"
    --hvy-warning: "#d4a017"
    --hvy-warning-bg: "#2a2310"
    --hvy-warning-border: "#6b5200"
    --hvy-warning-text: "#c79200"
    --hvy-success: "#4cae68"
    --hvy-success-bg: "#152b1e"
    --hvy-success-border: "#2e7a46"
section_defs:
  - name: Projects
    key: resume-projects
    template:
      id: projects
      title: Projects
      level: 1
      lock: true
      description: Project portfolio
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Projects"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PROJECT
              - DATES
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Project table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: project-record
            componentListItemLabel: project
            tags: project
            componentListBlocks: []
      children: []
    flavors:
      - name: tableform
        description: Preferred for longer project lists
        template:
          id: projects
          title: Projects
          level: 1
          lock: true
          description: Project portfolio
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Projects"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                component: table
                css: "margin: 0.5rem 0 0;"
                tags: table-header
                tableColumns:
                  - PROJECT
                  - DATES
                tableShowHeader: true
                tableRows: []
                lock: true
                description: Project table header
            - text: ""
              schema:
                component: component-list
                css: "margin: 0;"
                componentListComponent: project-record
                componentListItemLabel: project
                tags: project
                componentListBlocks: []
          children: []
      - name: linear
        description: Preferred for shorter project lists
        template:
          id: projects
          title: Projects
          level: 1
          lock: true
          description: Project portfolio
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Projects"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                component: component-list
                css: "margin: 0;"
                componentListComponent: project-linear-record
                componentListItemLabel: project
                tags: project
                componentListBlocks: []
          children: []
  - name: Publications
    key: resume-publications
    template:
      id: publications
      title: Publications
      level: 1
      lock: true
      description: Publications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Publications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PUBLICATION
              - PUBLISHER
              - DATE
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Publication table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: publication-record
            componentListItemLabel: publication
            tags: publication
            componentListBlocks: []
      children: []
    flavors:
      - name: tableform
        description: Preferred for longer publication lists
        template:
          id: publications
          title: Publications
          level: 1
          lock: true
          description: Publications
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Publications"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                component: table
                css: "margin: 0.5rem 0 0;"
                tags: table-header
                tableColumns:
                  - PUBLICATION
                  - PUBLISHER
                  - DATE
                tableShowHeader: true
                tableRows: []
                lock: true
                description: Publication table header
            - text: ""
              schema:
                component: component-list
                css: "margin: 0;"
                componentListComponent: publication-record
                componentListItemLabel: publication
                tags: publication
                componentListBlocks: []
          children: []
      - name: linear
        description: Preferred for shorter publication lists
        template:
          id: publications
          title: Publications
          level: 1
          lock: true
          description: Publications
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Publications"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                component: component-list
                css: "margin: 0;"
                componentListComponent: publication-linear-record
                componentListItemLabel: publication
                tags: publication
                componentListBlocks: []
          children: []
  - name: Awards
    key: resume-awards
    template:
      id: awards
      title: Awards
      level: 1
      lock: true
      description: Awards
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Awards"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - AWARD
              - ISSUER
              - DATE
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Award table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: award-record
            componentListItemLabel: award
            tags: award
            componentListBlocks: []
      children: []
  - name: Certifications
    key: resume-certifications
    template:
      id: certifications
      title: Certifications
      level: 1
      lock: true
      description: Certifications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Certifications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - "<!--hvy:alt {\"compact\":\"CERT\"}-->CERTIFICATION<!--/hvy:alt-->"
              - GIVEN BY
              - OBTAINED
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Certification table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: certification-record
            componentListItemLabel: certification
            tags: certification
            componentListBlocks: []
      children: []
  - name: Languages
    key: resume-languages
    template:
      id: languages
      title: Languages
      level: 1
      lock: false
      expanded: false
      location: sidebar
      description: Spoken and written languages information
      hideIfUnmodified: true
      tags: languages
      blocks:
        - text: "# Languages"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: language-record
            componentListItemLabel: language
            tags: language
            componentListBlocks: []
      children: []
  - name: Tabular Resume Section
    key: tabular-resume-section
    repeatable: true
    templateVariables:
      section_title:
        label: Section title
      row_label:
        label: Row label
      row_summary:
        label: Row summary
      row_details:
        label: Row details
    template:
      title: Tabular Resume Section
      level: 1
      lock: false
      description: An additional resume section with a table with expandable rows.
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# {% section_title %}"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
            placeholder: "# Section title"
        - text: ""
          schema:
            component: table
            css: "margin: 0;"
            lock: false
            tableColumns: ["ITEM", "SUMMARY"]
            tableShowHeader: true
            tableRows: []
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: resume-section-row
            componentListItemLabel: row
            componentListBlocks:
              - text: ""
                schema:
                  component: expandable
                  css: "margin: 0;"
                  expandableAlwaysShowStub: true
                  expandableExpanded: false
                  expandableStubBlocks:
                    children:
                      - text: ""
                        schema:
                          component: table
                          css: "margin: 0; margin-top: -1px;"
                          tableColumns: ["ITEM", "SUMMARY"]
                          tableShowHeader: false
                          tableRows:
                            - cells: ["{% row_label %}", "{% row_summary %}"]
                  expandableContentBlocks:
                    css: "padding: 0.5rem;"
                    children:
                      - text: "^section-heading^ ### {% row_label %}\n{% row_details | block %}"
                        schema:
                          component: text
                          placeholder: "Row details"
                          css: "margin: 0;"
                      - text: "Delete this starter row if it is not needed."
                        schema:
                          component: text
                          editorOnly: true
                          css: "margin: 0.35rem 0 0; color: var(--hvy-text-muted); font-style: italic;"
      children: []
  - name: History
    key: resume-history
    repeatable: false
    template:
      id: history
      title: Professional History
      level: 1
      lock: true
      description: Work history
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Professional History"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns: ["TITLE", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "DATES"]
            tableShowHeader: true
            tableRows: []
            lock: true
            description: History table header
        - text: ""
          schema:
            id: history-list
            component: component-list
            css: "margin: 0;"
            componentListComponent: history-record
            componentListItemLabel: job
            tags: history
            componentListBlocks: []
      children: []
    flavors:
      - name: tableform
        description: Preferred for longer histories (4 or more)
        template:
          id: history
          title: Professional History
          level: 1
          lock: true
          description: Work history
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Professional History"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                component: table
                css: "margin: 0.5rem 0 0;"
                tags: table-header
                tableColumns: ["TITLE", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "DATES"]
                tableShowHeader: true
                tableRows: []
                lock: true
                description: History table header
            - text: ""
              schema:
                id: history-list
                component: component-list
                css: "margin: 0;"
                componentListComponent: history-record
                componentListItemLabel: job
                tags: history
                componentListBlocks: []
          children: []
      - name: linear
        description: Preferred for shorter histories (3 or less)
        template:
          id: history
          title: Professional History
          level: 1
          lock: true
          description: Work history
          hideIfUnmodified: true
          tags: reciprocal-xref-source
          blocks:
            - text: "# Professional History"
              schema:
                component: text
                css: "margin: 0.5rem 0;"
            - text: ""
              schema:
                id: history-list
                component: component-list
                css: "margin: 0;"
                componentListComponent: history-linear-record
                componentListItemLabel: job
                tags: history
                componentListBlocks: []
          children: []
component_defs:
  - name: resume-section-row
    baseType: expandable
    description: Generic resume section table row
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["ITEM", "SUMMARY"]
              tableShowHeader: false
              tableRows:
                - cells: ["", ""]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: text
              placeholder: "Row details"
              css: "margin: 0;"
          - text: "Delete this starter row if it is not needed."
            schema:
              component: text
              editorOnly: true
              css: "margin: 0.35rem 0 0; color: var(--hvy-text-muted); font-style: italic;"
  - name: skill-xref-card
    baseType: xref-card
    description: Skill reference
    schema:
      xrefTargetTagFilter: skill
      css: "margin: 0.25rem 0;"
  - name: tool-tech-xref-card
    baseType: xref-card
    description: Tool / technology reference
    schema:
      xrefTargetTagFilter: tool
      css: "margin: 0.25rem 0;"
  - name: history-xref-card
    baseType: xref-card
    description: Work history reference
    schema:
      xrefTargetTagFilter: history
      css: "margin: 0.25rem 0;"
  - name: education-xref-card
    baseType: xref-card
    description: Education reference
    schema:
      xrefTargetTagFilter: education
      css: "margin: 0.25rem 0;"
  - name: award-xref-card
    baseType: xref-card
    description: Award reference
    schema:
      xrefTargetTagFilter: award
      css: "margin: 0.25rem 0;"
  - name: language-xref-card
    baseType: xref-card
    description: Language reference
    schema:
      xrefTargetTagFilter: language
      css: "margin: 0.25rem 0;"
  - name: certification-xref-card
    baseType: xref-card
    description: Certification reference
    schema:
      xrefTargetTagFilter: certification
      css: "margin: 0.25rem 0;"
  - name: publication-xref-card
    baseType: xref-card
    description: Publication reference
    schema:
      xrefTargetTagFilter: publication
      css: "margin: 0.25rem 0;"
  - name: project-xref-card
    baseType: xref-card
    description: Project reference
    schema:
      xrefTargetTagFilter: project
      css: "margin: 0.25rem 0;"
  - name: history-record
    baseType: expandable
    description: Work history organization entry
    templateVariables:
      role:
        label: Role / Title
      dates:
        label: Dates
      accomplishments:
        label: Accomplishments
    schema:
      tags: history
      xrefTitle: "{% role %}"
      xrefDetail: "{% organization %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["TITLE", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "DATES"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% role %}", "{% organization %}", "{% dates %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: "{% organization %}"
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: "{% location %}"
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: "{% role %}"
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: "{% description | block %}"
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "^section-heading^ #### Accomplishments"
            schema:
              component: text
              css: "margin: 0;"
          - text: "{% accomplishments | block %}"
            schema:
              component: text
              placeholder: accomplishments
              css: "margin: 0;"
          - component: skills-and-tools-tech-list
  - name: history-linear-record
    baseType: expandable
    description: Work history organization entry with an empty collapsed stub for linear history sections
    templateVariables:
      role:
        label: Role / Title
      date_range:
        label: Dates
      accomplishments:
        label: Accomplishments
    schema:
      tags: history
      xrefTitle: "{% role %}"
      xrefDetail: "{% organization %}"
      css: "margin: 0.35rem 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children: []
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: "{% organization %}"
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: "{% location %}"
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: "{% role %}"
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: "{% description | block %}"
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "^section-heading^ #### Accomplishments"
            schema:
              component: text
              css: "margin: 0;"
          - text: "{% accomplishments | block %}"
            schema:
              component: text
              placeholder: accomplishments
              css: "margin: 0;"
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Related skills and tools
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: skill-xref-card
                    componentListItemLabel: skill reference
                    css: "margin: 0;"
                    componentListBlocks: []
        - id: tools-technologies
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: tool-tech-xref-card
                    componentListItemLabel: tool / tech reference
                    css: "margin: 0;"
                    componentListBlocks: []
  - name: education-record
    baseType: expandable
    description: Education entry
    templateVariables:
      institution:
        label: School / University
      date_range:
        label: Date range
      gpa:
        label: GPA
    schema:
      tags: education
      xrefTitle: "{% degree %}"
      xrefDetail: "{% institution %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children: []
      expandableContentBlocks:
        children:
          - text: "^section-heading^ ### {% degree %}"
            schema:
              component: text
              css: "margin: 0 0 0.25rem;"
              placeholder: "Degree"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "{% institution %}"
                          schema:
                            component: text
