  <!--hvy:component-list:1 {}-->

   <!--hvy:skill-record {"id":"skill-reverse-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Reverse Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Analyzing existing systems, file formats, or tool internals to understand structure and behavior without access to original specifications.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Notes

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Applied primarily to understand undocumented formats and third-party tool internals for building compatible tooling.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Heavy Stack","xrefDetail":"05/2024 - present","xrefTarget":"project-heavy-stack"}-->

  <!--hvy:component-list:2 {}-->

   <!--hvy:skill-record {"id":"skill-library-development","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Library Development

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Designing and maintaining reusable software packages intended for use across multiple applications or by other developers.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Notes

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Built shared TypeScript platform packages that reduced duplicated code across products and improved consistency of internal tooling.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Heavy Stack","xrefDetail":"05/2024 - present","xrefTarget":"project-heavy-stack"}-->

  <!--hvy:component-list:3 {}-->

   <!--hvy:skill-record {"id":"skill-llm-prompt-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      LLM Prompt Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Designing and iterating on prompts and workflows that direct large language model behavior toward reliable, useful outputs in product contexts.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Notes

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Used to design AI-assisted editor workflows and autonomous agent pipelines. Focuses on structured output, fallback handling, and iterative refinement.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Autonomous Agent Hackathon","xrefDetail":"08/2023 - 08/2023","xrefTarget":"project-autonomous-agent-hackathon"}-->

  <!--hvy:component-list:4 {}-->

   <!--hvy:skill-record {"id":"skill-project-management","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      Project Management

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
