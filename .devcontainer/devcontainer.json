{
  "name": "heavy-file-format",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",
  // "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    "ghcr.io/devcontainers/features/node:2.0.0": {
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "ms-playwright.playwright",
        "vitest.explorer"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [
    5173
  ],
  "postCreateCommand": ". ${NVM_DIR}/nvm.sh && nvm install && nvm alias default \"$(cat .nvmrc)\" && nvm use default && npm run install:devcontainer",
  "postStartCommand": ". ${NVM_DIR}/nvm.sh && nvm use default >/dev/null",
  "portsAttributes": {
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "notify"
    }
  }
}
