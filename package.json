{
  "name": "heavy-file-format-ref-impl",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist-embed",
    "scripts/hvy-mcp-cli.mjs",
    "src",
    "AI-RESPONSE-FORMAT.md",
    "HVY-SPEC.md",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/embed.ts",
      "default": "./dist-embed/hvy-embed.js"
    },
    "./embed": {
      "types": "./src/embed.ts",
      "default": "./dist-embed/hvy-embed.js"
    },
    "./cli-core": {
      "types": "./src/cli-core/index.ts",
      "default": "./src/cli-core/index.ts"
    },
    "./mcp-cli-runner": "./scripts/hvy-mcp-cli.mjs",
    "./dist-embed/*": "./dist-embed/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "install:deps": "bash ./scripts/install-deps.sh",
    "install:pwdeps": "bash ./scripts/install-playwright-deps.sh",
    "install:devcontainer": "bash ./scripts/install-devcontainer.sh",
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:embed",
    "build:embed": "tsc -p tsconfig.app.json --noEmit && vite build --config vite.embed.config.ts",
    "prepare": "npm run build:embed",
    "preview": "vite preview",
    "browser:start": "node scripts/browser-harness.mjs start",
    "browser:smoke": "node scripts/browser-harness.mjs smoke",
    "browser:stop": "node scripts/browser-harness.mjs stop",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "dompurify": "^3.2.6",
    "flexsearch": "^0.8.212",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12",
    "mermaid": "^11.15.0",
    "pdfmake": "0.3.9",
    "sql.js": "^1.14.1",
    "turndown": "^7.2.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.6.0",
    "@types/sql.js": "^1.4.11",
    "@types/turndown": "^5.0.6",
    "brython": "^3.14.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.2.4"
  }
}
