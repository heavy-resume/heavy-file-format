<!--hvy: {"id":"tools-technologies","lock":true,"expanded":false,"location":"sidebar"}-->
#! Tools & Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Tools & Technologies

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"skill-record"}-->

  <!--hvy:component-list:0 {}-->

   <!--hvy:skill-record {"id":"tool-typescript","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      TypeScript

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0.4rem 0 0.1rem;"}-->
      #### Description

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0 0 0.35rem; margin-left: 0.5rem;"}-->
      Statically typed superset of JavaScript used for large-scale web applications, tooling, and shared platform packages.

    <!--hvy:expandable:content {}-->

