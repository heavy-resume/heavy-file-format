---
hvy_version: 0.1
title: Resume Example
reader_max_width: 60rem
ai-context: >-
  This is a resume document. Use the top-skills-tools-technologies section for featured
  xref-card links only; the skills and tools-technologies sidebar sections are the main
  reusable libraries for detailed skill/tool records. History, projects, and education
  each have a static table used only as the visible column header for the expandable
  record rows in the following component-list; keep both in reverse chronological order
  with newest entries first. History should use one
  expandable record per organization when roles are contiguous; put promotions, title
  changes, or adjacent date ranges at the same organization inside that single expanded
  record instead of creating duplicate organization rows. One project, degree, skill, or
  tool should usually be represented as one expandable reusable record. Local skills/tools
  lists inside history, project, and education records are supporting xrefs and should not
  be treated as the main libraries.
section_defaults:
  css: "margin: 0.5rem 0;"
text_line_styles:
  panel-heading:
    label: Panel heading
    css: "margin: 0 0 0.25rem;"
  section-heading:
    label: Section heading
    css: "margin: 0.5rem 0 0.25rem;"
  detail-heading:
    label: Detail heading
    css: "margin: 0.4rem 0 0.1rem;"
  detail-body:
    label: Detail body
    css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
theme:
  colors:
    --hvy-bg: "#0f1720"
    --hvy-bg-alt: "#161b22"
    --hvy-surface: "#17222d"
    --hvy-surface-alt: "#1c2733"
    --hvy-surface-tint: "#1f3448"
    --hvy-text: "#e7eef5"
    --hvy-text-alt: "#a3adbf"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#7db3d0"
    --hvy-accent-1-alt: "#5a8da8"
    --hvy-accent-1-text: "#fcfcfc"
    --hvy-accent-2: "#6fb3c1"
    --hvy-accent-2-alt: "#2d5d68"
    --hvy-button-bg: "#2d6a8a"
    --hvy-button-text: "#ffffff"
    --hvy-link-color: "#7bc0e8"
    --hvy-highlight-1: "rgba(125, 179, 208, 0.20)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.25)"
    --hvy-border: "#2a3340"
    --hvy-border-alt: "#3d4756"
    --hvy-border-input: "#334152"
    --hvy-border-translucent: "rgba(42, 51, 64, 0.92)"
    --hvy-ghost-border: "rgba(231, 238, 245, 0.22)"
    --hvy-xref-card-bg: "rgba(255, 255, 255, 0.04)"
    --hvy-xref-card-hover-bg: "rgba(255, 255, 255, 0.08)"
    --hvy-table-header: "#1f2a37"
    --hvy-table-row-bg-1: "#17222d"
    --hvy-table-row-bg-2: "#1c2835"
    --hvy-icon-muted: "rgba(231, 238, 245, 0.33)"
    --hvy-shadow: "rgba(0, 0, 0, 0.20)"
    --hvy-shadow-md: "rgba(0, 0, 0, 0.30)"
    --hvy-shadow-lg: "rgba(0, 0, 0, 0.40)"
    --hvy-overlay: "rgba(0, 0, 0, 0.60)"
    --hvy-danger: "#c05050"
    --hvy-warning: "#d4a017"
    --hvy-warning-bg: "#2a2310"
    --hvy-warning-border: "#6b5200"
    --hvy-warning-text: "#c79200"
    --hvy-success: "#4cae68"
    --hvy-success-bg: "#152b1e"
    --hvy-success-border: "#2e7a46"
component_defs:
  - name: history-record
    baseType: expandable
    description: Work history organization entry
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;  margin-top: -1px;"
              tableColumns: ["YEAR", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "TITLE"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% years %}", "{% organization %}", "{% role %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: "{% organization %}"
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: "{% location %}"
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: "{% role %}"
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: "{% description | block %}"
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "^section-heading^ #### Accomplishments"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: accomplishments
              css: "margin: 0;"
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Related skills and tools
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: xref-card
                    componentListItemLabel: skill
                    css: "margin: 0;"
                    componentListBlocks: []
        - id: tools-technologies
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: xref-card
                    componentListItemLabel: tool / tech
                    css: "margin: 0;"
                    componentListBlocks: []
  - name: education-record
    baseType: expandable
    description: Education entry
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["DEGREE", "INSTITUTION", "LOCATION"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% degree %}", "{% institution %}", "{% location %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "{% institution %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "School / University"
                        - text: "{% location %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Location"
                        - text: "{% gpa %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "GPA"
                - id: education-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Start Year – End Year"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
          - text: "^section-heading^ #### Classes"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: classes
              css: "margin: 0;"
  - name: project-record
    baseType: expandable
    description: Project entry
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;  margin-top: -1px;"
              tableColumns: ["PROJECT", "DATE"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% project %}", "{% date_range %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: project-title
                  block:
                    text: "{% project %}"
                    schema:
                      component: text
                      css: "margin: 0;"
                      placeholder: "Project name"
                - id: project-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Date range"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Project description"
          - text: "{% link %}"
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Project link"
          - component: skills-and-tools-tech-list
  - name: skill-record-experience-section
    baseType: container
    description: Related work history
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "^detail-heading^ #### Experience"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-education-section
    baseType: container
    description: Related education
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "^detail-heading^ #### Education"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-projects-section
    baseType: container
    description: Related projects
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "^detail-heading^ #### Projects"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListBlocks: []
  - name: skill-record-section
    baseType: container
    description: Skill detail group
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ {% section_title %}"
          schema:
            component: text
            css: "margin: 0;"
            placeholder: "#### Section title"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: skill-record-entry
            componentListBlocks: []
  - name: skill-record
    baseType: expandable
    description: Skill or tool details
    schema:
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        children:
          - text: "### {% skill %}"
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "### Skill name"
      expandableContentBlocks:
        lock: false
        css: "padding: 0.5rem;"
        children:
          - text: |-
              ^detail-heading^ #### Description
              ^detail-body^ {% description | block %}
              ^detail-heading^ #### Notes
              ^detail-body^ {% notes | block %}
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Description and notes"
          - component: skill-record-experience-section
          - component: skill-record-education-section
          - component: skill-record-projects-section
---

<!--hvy: {"id":"header","lock":true,"contained":false,"tags":"identity, contact, title","description":"Resume identity header"}-->
#! Info

 <!--hvy:text {"css":"margin-bottom: 0;","align":"center"}-->
  # Avery Hart

 <!--hvy:text {"css":"margin-top: 0;","align":"center"}-->
  [AY-vuh-ree HART]

 <!--hvy:text {"css":"margin: 0.5rem 0; margin-top: 1rem;","align":"center"}-->
  Senior Software Engineer

<!--hvy: {"id":"summary","lock":true,"contained":true,"tags":"summary, highlights, profile","description":"Professional summary"}-->
#! Summary

 <!--hvy:expandable {"css":"padding:0.25rem;","expandableAlwaysShowStub":true,"expandableExpanded":false,"lock":true}-->

  <!--hvy:expandable:stub {}-->

   <!--hvy:text {"css":"margin-bottom: 0;","placeholder":"Add a short professional summary and elaborate in the expanded section"}-->
    ## Summary

   <!--hvy:text {"css":"margin-top: 0;"}-->
    Product-minded software engineer focused on developer tooling, AI workflows, and reusable systems that make complex products easier to ship and maintain.

  <!--hvy:expandable:content {}-->

   <!--hvy:text {"css":"margin: 0;"}-->
    ^detail-body^ Builds polished internal tools that reduce friction for engineers and product teams.
    ^detail-body^ Comfortable moving between frontend UX, platform design, and AI-assisted workflows.
    ^detail-body^ Enjoys turning messy, high-context problems into repeatable systems and clear documentation.

<!--hvy: {"id":"locations","lock":true,"contained":true,"location":"sidebar","tags":"sidebar, location, preferences","description":"Location preferences"}-->
#! Locations

 <!--hvy:text {"css":"margin: 0.5rem 0; line-height: 1.5;","placeholder":"location, target location","fillIn":true,"lock":true}-->
  **Location:** Seattle, WA

  **Target Location(s):** Greater Seattle Area, San Francisco

<!--hvy: {"id":"top-skills-tools-technologies","lock":true,"tags":"featured, top-skills, xrefs","description":"Featured skills and tools & technology experience"}-->
#! Featured Skills, Tools, and Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Featured

 <!--hvy:grid {"css":"margin: 0.5rem 0; gap: 0.75rem;","gridColumns":2,"lock":true}-->

  <!--hvy:grid:0 {"id":"top-skills"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:container:0 {}-->

     <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
      ## Skills

    <!--hvy:container:1 {}-->

     <!--hvy:component-list {"id":"top-skills-list","componentListComponent":"xref-card","css":"margin: 0;","align":"center"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Software Engineering","xrefDetail":"Core strength","xrefTarget":"skill-software-engineering"}-->

      <!--hvy:component-list:1 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Library Development","xrefDetail":"Reusable systems","xrefTarget":"skill-library-development"}-->

      <!--hvy:component-list:2 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"LLM Prompt Engineering","xrefDetail":"Product workflow design","xrefTarget":"skill-llm-prompt-engineering"}-->

  <!--hvy:grid:1 {"id":"top-tools-technologies"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:container:0 {}-->

     <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
      ## Tools & Technologies

    <!--hvy:container:1 {}-->

     <!--hvy:component-list {"id":"top-tools-technologies-list","componentListComponent":"xref-card","css":"margin: 0;","align":"center"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"TypeScript","xrefDetail":"Primary application language","xrefTarget":"tool-typescript"}-->

      <!--hvy:component-list:1 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Python","xrefDetail":"Automation and prototyping","xrefTarget":"tool-python"}-->

      <!--hvy:component-list:2 {}-->

       <!--hvy:xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Developer Containers","xrefDetail":"Reproducible local environments","xrefTarget":"tool-developer-containers"}-->

<!--hvy: {"id":"skills","lock":true,"expanded":false,"location":"sidebar","tags":"sidebar, skills-reference, skill-details","description":"Skills reference list"}-->
#! Skills

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Skills

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"skill-record","componentListItemLabel":"skill","componentListDefaultSortKey":"Strength","componentListDefaultSortDirection":"desc"}-->

  <!--hvy:component-list:0 {}-->

   <!--hvy:skill-record {"id":"skill-software-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Software Engineering","Strength":98},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Software Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing, building, and maintaining software systems with a focus on reliability, maintainability, and developer experience.
      ^detail-heading^ #### Notes
      ^detail-body^ Core strength. Approaches engineering as a systems discipline — prioritizing clear APIs, testable boundaries, and incremental delivery over clever solutions.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Experience

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Senior Software Engineer","xrefDetail":"Northwind Labs","xrefTarget":"history-northwind-labs-senior-software-engineer"}-->

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Education

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"B.S. Computer Science","xrefDetail":"University of Washington","xrefTarget":"education-bs-computer-science"}-->

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Heavy Stack","xrefDetail":"05/2024 - present","xrefTarget":"project-heavy-stack"}-->

  <!--hvy:component-list:1 {}-->

   <!--hvy:skill-record {"id":"skill-reverse-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Reverse Engineering","Strength":87},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Reverse Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Analyzing existing systems, file formats, or tool internals to understand structure and behavior without access to original specifications.
      ^detail-heading^ #### Notes
      ^detail-body^ Applied primarily to understand undocumented formats and third-party tool internals for building compatible tooling.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Heavy Stack","xrefDetail":"05/2024 - present","xrefTarget":"project-heavy-stack"}-->

  <!--hvy:component-list:2 {}-->

   <!--hvy:skill-record {"id":"skill-library-development","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Library Development","Strength":93},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Library Development

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing and maintaining reusable software packages intended for use across multiple applications or by other developers.
      ^detail-heading^ #### Notes
      ^detail-body^ Built shared TypeScript platform packages that reduced duplicated code across products and improved consistency of internal tooling.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Heavy Stack","xrefDetail":"05/2024 - present","xrefTarget":"project-heavy-stack"}-->

  <!--hvy:component-list:3 {}-->

   <!--hvy:skill-record {"id":"skill-llm-prompt-engineering","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"LLM Prompt Engineering","Strength":91},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### LLM Prompt Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing and iterating on prompts and workflows that direct large language model behavior toward reliable, useful outputs in product contexts.
      ^detail-heading^ #### Notes
      ^detail-body^ Used to design AI-assisted editor workflows and autonomous agent pipelines. Focuses on structured output, fallback handling, and iterative refinement.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Autonomous Agent Hackathon","xrefDetail":"08/2023 - 08/2023","xrefTarget":"project-autonomous-agent-hackathon"}-->

  <!--hvy:component-list:4 {}-->

   <!--hvy:skill-record {"id":"skill-project-management","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Project Management","Strength":84},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Project Management

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Coordinating people, timelines, and deliverables to move work from idea to shipped with clear ownership and minimal ceremony.
      ^detail-heading^ #### Notes
      ^detail-body^ Lightweight approach — async-first communication and clear ownership over process overhead. Comfortable leading small cross-functional efforts.

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Projects

    <!--hvy:expandable:content {}-->

     <!--hvy:component-list {"componentListComponent":"xref-card","css":"margin: 0;"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:xref-card {"css":"margin: 0.25rem 0;","xrefTitle":"Autonomous Agent Hackathon","xrefDetail":"08/2023 - 08/2023","xrefTarget":"project-autonomous-agent-hackathon"}-->

<!--hvy: {"id":"tools-technologies","lock":true,"expanded":false,"location":"sidebar","tags":"sidebar, tools-reference, technologies, tool-details","description":"Tools and technologies reference list"}-->
#! Tools & Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Tools & <!--hvy:alt {"compact":"Tech"}-->Technologies<!--/hvy:alt-->

