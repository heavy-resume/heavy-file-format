 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Projects

 <!--hvy:table {"css":"margin: 0.5rem 0 0;","tags":"table-header","tableColumns":["PROJECT","DATES"],"tableShowHeader":true,"tableRows":[],"lock":true,"description":"Project table header"}-->

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"project-record","componentListItemLabel":"project"}-->

<!--hvy: {"id":"education","lock":true,"description":"Education","hideIfUnmodified":true}-->
#! Education

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Education

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"education-record","componentListItemLabel":"education record"}-->

<!--hvy: {"id":"template-maintenance","editorOnly":true,"lock":true,"contained":true,"description":"Template maintenance scripts"}-->
#! Template Maintenance

 <!--hvy:plugin {"id":"remove-featured-xref-helper","editorOnly":true,"plugin":"dev.heavy.scripting","pluginConfig":{"version":"0.1"}}-->
  def has_xref(list_id):
      try:
          return "<!--hvy:xref-card" in doc.tool.view_component(component_ref=list_id)
      except Exception:
          return False

  if has_xref("top-skills-list") and has_xref("top-tools-technologies-list"):
      try:
          doc.tool.remove_component(component_ref="featured-xref-helper")
      except Exception:
          pass
      try:
          doc.tool.remove_component(component_ref="remove-featured-xref-helper")
      except Exception:
          pass
