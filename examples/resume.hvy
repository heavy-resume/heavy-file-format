---
hvy_version: 0.1
title: Resume Example
reader_max_width: 60rem
ai-context: >-
  This is a resume document. Use the top-skills-tools-technologies section for featured
  reference cards only; the skills and tools-technologies sidebar sections are the main
  reusable libraries for detailed skill/tool records. History, projects, and education
  each have a static table used only as the visible column header for the expandable
  record rows in the following component-list; keep them in reverse chronological order
  with newest entries first. History should use one
  expandable record per organization when roles are contiguous; put promotions, title
  changes, or adjacent date ranges at the same organization inside that single expanded
  record instead of creating duplicate organization rows. One project, publication,
  certification, degree, skill, or tool should usually be represented as one expandable
  reusable record. Local skills/tools lists inside history, project, publication,
  certification, and education records are supporting references and should not be treated as
  the main libraries.
section_defaults:
  css: "margin: 0.5rem 0;"
text_line_styles:
  panel-heading:
    label: Panel heading
    css: "margin: 0 0 0.25rem;"
  section-heading:
    label: Section heading
    css: "margin: 0.5rem 0 0.25rem;"
  detail-heading:
    label: Detail heading
    css: "margin: 0.4rem 0 0.1rem;"
  detail-body:
    label: Detail body
    css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
theme:
  colors:
    --hvy-bg: "#0f1720"
    --hvy-bg-alt: "#161b22"
    --hvy-surface: "#17222d"
    --hvy-surface-alt: "#1c2733"
    --hvy-surface-tint: "#1f3448"
    --hvy-text: "#e7eef5"
    --hvy-text-alt: "#a3adbf"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#7db3d0"
    --hvy-accent-1-alt: "#5a8da8"
    --hvy-accent-1-text: "#fcfcfc"
    --hvy-accent-2: "#6fb3c1"
    --hvy-accent-2-alt: "#2d5d68"
    --hvy-button-bg: "#2d6a8a"
    --hvy-button-text: "#ffffff"
    --hvy-link-color: "#7bc0e8"
    --hvy-highlight-1: "rgba(125, 179, 208, 0.20)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.25)"
    --hvy-border: "#2a3340"
    --hvy-border-alt: "#3d4756"
    --hvy-border-input: "#334152"
    --hvy-border-translucent: "rgba(42, 51, 64, 0.92)"
    --hvy-ghost-border: "rgba(231, 238, 245, 0.22)"
    --hvy-xref-card-bg: "rgba(255, 255, 255, 0.04)"
    --hvy-xref-card-hover-bg: "rgba(255, 255, 255, 0.08)"
    --hvy-table-header: "#1f2a37"
    --hvy-table-row-bg-1: "#17222d"
    --hvy-table-row-bg-2: "#1c2835"
    --hvy-icon-muted: "rgba(231, 238, 245, 0.33)"
    --hvy-shadow: "rgba(0, 0, 0, 0.20)"
    --hvy-shadow-md: "rgba(0, 0, 0, 0.30)"
    --hvy-shadow-lg: "rgba(0, 0, 0, 0.40)"
    --hvy-overlay: "rgba(0, 0, 0, 0.60)"
    --hvy-danger: "#c05050"
    --hvy-warning: "#d4a017"
    --hvy-warning-bg: "#2a2310"
    --hvy-warning-border: "#6b5200"
    --hvy-warning-text: "#c79200"
    --hvy-success: "#4cae68"
    --hvy-success-bg: "#152b1e"
    --hvy-success-border: "#2e7a46"
section_defs:
  - name: Projects
    key: resume-projects
    template:
      id: projects
      title: Projects
      level: 1
      lock: true
      description: Project portfolio
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Projects"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PROJECT
              - DATES
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Project table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: project-record
            componentListItemLabel: project
            tags: project
            componentListBlocks: []
      children: []
  - name: Publications
    key: resume-publications
    template:
      id: publications
      title: Publications
      level: 1
      lock: true
      description: Publications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Publications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - PUBLICATION
              - PUBLISHER
              - DATE
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Publication table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: publication-record
            componentListItemLabel: publication
            tags: publication
            componentListBlocks: []
      children: []
  - name: Certifications
    key: resume-certifications
    template:
      id: certifications
      title: Certifications
      level: 1
      lock: true
      description: Certifications
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Certifications"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
        - text: ""
          schema:
            component: table
            css: "margin: 0.5rem 0 0;"
            tags: table-header
            tableColumns:
              - "<!--hvy:alt {\"compact\":\"CERT\"}-->CERTIFICATION<!--/hvy:alt-->"
              - ISSUER
              - OBTAINED
            tableShowHeader: true
            tableRows: []
            lock: true
            description: Certification table header
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: certification-record
            componentListItemLabel: certification
            tags: certification
            componentListBlocks: []
      children: []
  - name: Resume Section
    key: resume-section
    repeatable: true
    template:
      title: Resume Section
      level: 1
      lock: true
      description: Additional resume section
      hideIfUnmodified: true
      tags: reciprocal-xref-source
      blocks:
        - text: "# Resume Section"
          schema:
            component: text
            css: "margin: 0.5rem 0;"
            placeholder: "# Section title"
        - text: ""
          schema:
            component: text
            css: "margin: 0;"
            placeholder: "Add section details, records, and any relevant skill or tool references."
      children: []
component_defs:
  - name: skill-xref-card
    baseType: xref-card
    description: Skill reference
    schema:
      xrefTargetTagFilter: skill
      css: "margin: 0.25rem 0;"
  - name: tool-tech-xref-card
    baseType: xref-card
    description: Tool / technology reference
    schema:
      xrefTargetTagFilter: tool
      css: "margin: 0.25rem 0;"
  - name: history-xref-card
    baseType: xref-card
    description: Work history reference
    schema:
      xrefTargetTagFilter: history
      css: "margin: 0.25rem 0;"
  - name: education-xref-card
    baseType: xref-card
    description: Education reference
    schema:
      xrefTargetTagFilter: education
      css: "margin: 0.25rem 0;"
  - name: certification-xref-card
    baseType: xref-card
    description: Certification reference
    schema:
      xrefTargetTagFilter: certification
      css: "margin: 0.25rem 0;"
  - name: publication-xref-card
    baseType: xref-card
    description: Publication reference
    schema:
      xrefTargetTagFilter: publication
      css: "margin: 0.25rem 0;"
  - name: project-xref-card
    baseType: xref-card
    description: Project reference
    schema:
      xrefTargetTagFilter: project
      css: "margin: 0.25rem 0;"
  - name: history-record
    baseType: expandable
    description: Work history organization entry
    schema:
      tags: history
      xrefTitle: "{% role %}"
      xrefDetail: "{% organization %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["TITLE", "<!--hvy:alt {\"compact\":\"ORG\"}-->ORGANIZATION<!--/hvy:alt-->", "YEAR(S)"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% role %}", "{% organization %}", "{% years %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: "{% organization %}"
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: "{% location %}"
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: "{% role %}"
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: "{% description | block %}"
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "^section-heading^ #### Accomplishments"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: accomplishments
              css: "margin: 0;"
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: Related skills and tools
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: skill-xref-card
                    componentListItemLabel: skill reference
                    css: "margin: 0;"
                    componentListBlocks: []
        - id: tools-technologies
          align: center
          block:
            text: ""
            schema:
              component: container
              css: "margin: 0;"
              containerBlocks:
                - text: "^panel-heading^ #### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0;"
                - text: ""
                  schema:
                    component: component-list
                    componentListComponent: tool-tech-xref-card
                    componentListItemLabel: tool / tech reference
                    css: "margin: 0;"
                    componentListBlocks: []
  - name: education-record
    baseType: expandable
    description: Education entry
    schema:
      tags: education
      xrefTitle: "{% degree %}"
      xrefDetail: "{% institution %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children: []
      expandableContentBlocks:
        children:
          - text: "^section-heading^ ### {% degree %}"
            schema:
              component: text
              css: "margin: 0 0 0.25rem;"
              placeholder: "Degree"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "{% institution %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "School / University"
                        - text: "{% location %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Location"
                        - text: "{% gpa %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "GPA"
                - id: education-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Start Year - End Year"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
          - text: "^section-heading^ #### Classes"
            schema:
              component: text
              css: "margin: 0;"
          - text: ""
            schema:
              component: text
              placeholder: classes
              css: "margin: 0;"
  - name: certification-record
    baseType: expandable
    description: Certification entry
    schema:
      tags: certification
      xrefTitle: "{% name %}"
      xrefDetail: "{% obtained_from %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["<!--hvy:alt {\"compact\":\"CERT\"}-->CERTIFICATION<!--/hvy:alt-->", "ISSUER", "OBTAINED"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% name %}", "{% obtained_from %}", "{% obtained_month %}/{% obtained_year %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: certification-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "^section-heading^ ### {% name %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Certification name"
                        - text: "{% obtained_from %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "Obtained from"
                - id: certification-obtained-date
                  block:
                    text: "{% obtained_month %}/{% obtained_year %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Obtained month / year"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
  - name: publication-record
    baseType: expandable
    description: Publication entry
    schema:
      tags: publication
      xrefTitle: "{% name %}"
      xrefDetail: "{% publisher %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["PUBLICATION", "PUBLISHER", "DATE"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% name %}", "{% publisher %}", "{% date %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: publication-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: "^section-heading^ ### {% name %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Publication name"
                        - text: "{% authors %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Authors"
                        - text: "{% publisher %}"
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Publisher"
                        - text: "{% employer_short_name %}"
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "Employer short name"
                - id: publication-date
                  block:
                    text: "{% date %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Publication date"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - text: "{% url %}"
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Publication URL"
          - component: skills-and-tools-tech-list
  - name: project-record
    baseType: expandable
    description: Project entry
    schema:
      tags: project
      xrefTitle: "{% project %}"
      xrefDetail: "{% date_range %}"
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0; margin-top: -1px;"
              tableColumns: ["PROJECT", "DATES"]
              tableShowHeader: false
              tableRows:
                - cells: ["{% project %}", "{% date_range %}"]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: project-title
                  block:
                    text: "{% project %}"
                    schema:
                      component: text
                      css: "margin: 0;"
                      placeholder: "Project name"
                - id: project-date-range
                  block:
                    text: "{% date_range %}"
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Date range"
          - text: "{% description | block %}"
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Project description"
          - text: "{% link %}"
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Project link"
          - component: skills-and-tools-tech-list
  - name: skill-record-experience-section
    baseType: container
    description: Related work history
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Experience"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: history-xref-card
            componentListItemLabel: history reference
            componentListBlocks: []
  - name: skill-record-education-section
    baseType: container
    description: Related education
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Education"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: education-xref-card
            componentListItemLabel: education reference
            componentListBlocks: []
  - name: skill-record-projects-section
    baseType: container
    description: Related projects
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ #### Projects"
          schema:
            component: text
            css: "margin: 0;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: project-xref-card
            componentListItemLabel: project reference
            componentListBlocks: []
  - name: skill-record-section
    baseType: container
    description: Skill detail group
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: "^detail-heading^ {% section_title %}"
          schema:
            component: text
            css: "margin: 0;"
            placeholder: "#### Section title"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: skill-record-entry
            componentListItemLabel: detail
            componentListBlocks: []
  - name: skill-record
    baseType: expandable
    description: Skill or tool details
    schema:
      xrefTitle: "{% skill %}"
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        children:
          - text: "### {% skill %}"
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "### Skill name"
      expandableContentBlocks:
        lock: false
        css: "padding: 0.5rem;"
        children:
          - text: |-
              ^detail-heading^ #### Description
              ^detail-body^ {% description | block %}
              ^detail-heading^ #### Notes
              ^detail-body^ {% notes | block %}
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Description and notes"
---

<!--hvy: {"id":"header","lock":true,"contained":false,"description":"Resume identity header","priority":true}-->
#! Info

 <!--hvy:text {"css":"margin-bottom: 0;","align":"center"}-->
  # Avery Hart

 <!--hvy:text {"css":"margin-top: 0;","align":"center"}-->
  [AY-vuh-ree HART]

 <!--hvy:text {"css":"margin: 0.5rem 0; margin-top: 1rem;","align":"center"}-->
  Senior Software Engineer

<!--hvy: {"id":"summary","lock":true,"contained":true,"description":"Professional summary","priority":true}-->
#! Summary

 <!--hvy:expandable {"css":"padding:0.25rem;","expandableAlwaysShowStub":true,"expandableExpanded":false,"lock":true}-->

  <!--hvy:expandable:stub {}-->

   <!--hvy:text {"css":"margin-bottom: 0;","placeholder":"Add a short professional summary and elaborate in the expanded section"}-->
    # Summary

   <!--hvy:text {"css":"margin-top: 0;"}-->
    Product-minded software engineer focused on developer tooling, AI workflows, and reusable systems that make complex products easier to ship and maintain.

  <!--hvy:expandable:content {}-->

   <!--hvy:text {"css":"margin: 0;"}-->
    ^detail-body^ Builds polished internal tools that reduce friction for engineers and product teams.
    ^detail-body^ Comfortable moving between frontend UX, platform design, and AI-assisted workflows.
    ^detail-body^ Enjoys turning messy, high-context problems into repeatable systems and clear documentation.

<!--hvy: {"id":"locations","lock":true,"contained":true,"location":"sidebar","description":"Location preferences"}-->
#! Locations

 <!--hvy:text {"css":"margin: 0.5rem 0; line-height: 1.5;","placeholder":"location, target location","fillIn":true,"lock":true}-->
  **Location:** Seattle, WA

  **Target Location(s):** Greater Seattle Area, San Francisco

<!--hvy: {"id":"top-skills-tools-technologies","lock":true,"description":"Featured skills and tools & technology experience","priority":true}-->
#! Featured Skills, Tools, and Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Featured

 <!--hvy:grid {"css":"margin: 0.5rem 0; gap: 0.75rem;","gridColumns":2,"lock":true}-->

  <!--hvy:grid:0 {"id":"top-skills"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:container:0 {}-->

     <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
      ## Skills

    <!--hvy:container:1 {}-->

     <!--hvy:component-list {"id":"top-skills-list","componentListComponent":"skill-xref-card","componentListItemLabel":"skill reference","css":"margin: 0;","align":"center"}-->

      <!--hvy:component-list:0 {}-->

       <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Software Engineering","xrefDetail":"Core strength","xrefTarget":"skill-software-engineering"}-->

      <!--hvy:component-list:1 {}-->

       <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Library Development","xrefDetail":"Reusable systems","xrefTarget":"skill-library-development"}-->

      <!--hvy:component-list:2 {}-->

       <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"LLM Prompt Engineering","xrefDetail":"Product workflow design","xrefTarget":"skill-llm-prompt-engineering"}-->

  <!--hvy:grid:1 {"id":"top-tools-technologies"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:container:0 {}-->

     <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
      ## Tools & Technologies

    <!--hvy:container:1 {}-->

     <!--hvy:component-list {"id":"top-tools-technologies-list","componentListComponent":"tool-tech-xref-card","componentListItemLabel":"tool / tech reference","css":"margin: 0;","align":"center"}-->

      <!--hvy:component-list:0 {}-->

