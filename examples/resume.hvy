 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Publications

 <!--hvy:table {"css":"margin: 0.5rem 0 0;","tags":"table-header","tableColumns":["PUBLICATION","PUBLISHER","DATE"],"tableShowHeader":true,"tableRows":[],"lock":true,"description":"Publication table header"}-->

