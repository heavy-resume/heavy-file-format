<!--hvy: {"id":"template-maintenance","lock":true,"expanded":true,"highlight":false,"editorOnly":true,"description":"Template maintenance scripts"}-->
#! Template Maintenance

 <!--hvy:plugin {"id":"remove-featured-xref-helper","editorOnly":true,"plugin":"dev.hvy.scripting","pluginConfig":{"version":"0.1"}}-->
  def has_xref(list_id):
      try:
          raw = doc.tool.view_component(component_ref=list_id)
      except Exception:
          return False
      return '"xrefTarget":"' in raw or '"xrefTarget": "' in raw
  
  if has_xref("top-skills-list") or has_xref("top-tools-technologies-list"):
      try:
          doc.tool.remove_component(component_ref="featured-xref-helper")
      except Exception:
          pass
      try:
          doc.tool.remove_component(component_ref="remove-featured-xref-helper")
      except Exception:
          pass

 <!--hvy:plugin {"id":"sync-reciprocal-xrefs","editorOnly":true,"plugin":"dev.hvy.scripting","pluginConfig":{"version":"0.1","maxLines":200000}}-->
  SOURCE_TAG = "reciprocal-xref-source"
  GENERATED_TAG = "reciprocal-xref-generated"
  TARGET_TAGS = ["skill", "tool"]
  
  def safe_id(value):
      out = ""
      for ch in value.lower():
          out += ch if ("a" <= ch <= "z") or ("0" <= ch <= "9") else "-"
      while "--" in out:
          out = out.replace("--", "-")
      return out.strip("-") or "item"
  
  targets = {}
  groups = {}
  for record in doc.tool.get_updated_components("skill-record"):
      is_target = False
      for tag in TARGET_TAGS:
          if record.has_tag(tag):
              is_target = True
      if is_target:
          targets[record.id] = record
          groups[record.id] = {}
  
  scanned_xrefs = 0
  matched_xrefs = 0
  for xref in doc.tool.get_updated_components("xref"):
      scanned_xrefs += 1
      source_section = xref.get_parent_by_tag(SOURCE_TAG)
      target_id = str(xref.get("xrefTarget") or "")
      target = targets.get(target_id)
      if not source_section or not target:
          continue
      matched_xrefs += 1
      source = xref.get_ancestor_record(" ".join(TARGET_TAGS)) or source_section
      group_key = source.section_id
      if group_key not in groups[target.id]:
          groups[target.id][group_key] = []
      seen = False
      for item in groups[target.id][group_key]:
          if item.id == source.id:
              seen = True
      if not seen:
          groups[target.id][group_key].append(source)
  
  generated_cards = 0
  for target_id in sorted(targets.keys()):
      target = targets[target_id]
      target.remove_children_by_tag(GENERATED_TAG)
      for group_key in sorted(groups[target_id].keys()):
          sources = groups[target_id][group_key]
          if not sources:
              continue
          first = sources[0]
          group_id = target.id + "-reciprocal-" + safe_id(group_key)
          heading = target.append_child("text")
          heading.set("id", group_id + "-heading")
          heading.set("tags", GENERATED_TAG)
          heading.set("css", "margin: 0;")
          heading.set("text", "^detail-heading^ #### " + first.section_title)
          cards = target.append_child("component-list")
          cards.set("id", group_id + "-list")
          cards.set("tags", GENERATED_TAG)
          cards.set("css", "margin: 0;")
          cards.set("componentListComponent", "xref-card")
          cards.set("componentListItemLabel", "reciprocal reference")
          for source in sources:
              card = cards.append_child("xref-card", None, "", "component-list")
              card.set("id", target.id + "-from-" + safe_id(source.id))
              card.set("tags", GENERATED_TAG)
              card.set("xrefTitle", source.get("xrefTitle") or source.first_table_cell(0) or source.id)
              card.set("xrefDetail", source.get("xrefDetail") or source.first_table_cell(1) or "")
              card.set("xrefTarget", source.id)
              generated_cards += 1
