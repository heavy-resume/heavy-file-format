   <!--hvy:text {"css":"margin-bottom: 0;"}-->
     # Summary

  <!--hvy:expandable:stub {}-->

   <!--hvy:text {"css":"margin-top: 0;","placeholder":"Add a short professional summary and elaborate in the expanded section"}-->

  <!--hvy:expandable:content {}-->

   <!--hvy:text {"css":"margin: 0;","placeholder":"Add expanded summary details"}-->

<!--hvy: {"id":"locations","lock":true,"contained":true,"location":"sidebar","description":"Location preferences","hideIfUnmodified":true}-->
#! Locations

 <!--hvy:text {"css":"margin: 0.5rem 0; line-height: 1.5;","placeholder":"location, target location","fillIn":true,"lock":true}-->
  **Location:** <!-- value -->

  **Target Location(s):** <!-- value -->

<!--hvy: {"id":"top-skills-tools-technologies","lock":true,"description":"Featured skills and tools & technology experience","hideIfUnmodified":true,"priority":true}-->
#! Featured Skills, Tools, and Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
