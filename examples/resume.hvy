---

<!--hvy: {"id":"header","lock":true,"contained":false,"description":"Resume identity header","priority":true}-->
#! Info

 <!--hvy:text {"css":"margin-bottom: 0;","align":"center"}-->
  # Avery Hart

 <!--hvy:text {"css":"margin-top: 0;","align":"center"}-->
  [AY-vuh-ree HART]

 <!--hvy:text {"css":"margin: 0.5rem 0; margin-top: 1rem;","align":"center"}-->
  Senior Software Engineer

<!--hvy: {"id":"summary","lock":true,"contained":true,"description":"Professional summary","priority":true}-->
#! Summary

 <!--hvy:expandable {"css":"padding:0.25rem;","expandableAlwaysShowStub":true,"expandableExpanded":false,"lock":true}-->

  <!--hvy:expandable:stub {}-->

   <!--hvy:text {"css":"margin-bottom: 0;","placeholder":"Add a short professional summary and elaborate in the expanded section"}-->
    # Summary

   <!--hvy:text {"css":"margin-top: 0;"}-->
    Product-minded software engineer focused on developer tooling, AI workflows, and reusable systems that make complex products easier to ship and maintain.

  <!--hvy:expandable:content {}-->

   <!--hvy:text {"css":"margin: 0;"}-->
    ^detail-body^ Builds polished internal tools that reduce friction for engineers and product teams.
    ^detail-body^ Comfortable moving between frontend UX, platform design, and AI-assisted workflows.
    ^detail-body^ Enjoys turning messy, high-context problems into repeatable systems and clear documentation.

<!--hvy: {"id":"locations","lock":true,"contained":true,"location":"sidebar","description":"Location preferences"}-->
#! Locations

 <!--hvy:text {"css":"margin: 0.5rem 0; line-height: 1.5;","placeholder":"location, target location","fillIn":true,"lock":true}-->
  **Location:** Seattle, WA

  **Target Location(s):** Greater Seattle Area, San Francisco

<!--hvy: {"id":"top-skills-tools-technologies","lock":true,"description":"Featured skills and tools & technology experience","priority":true}-->
#! Featured Skills, Tools, and Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Featured

 <!--hvy:grid {"css":"margin: 0.5rem 0; gap: 0.75rem;","gridColumns":2,"lock":true}-->

  <!--hvy:grid:0 {"id":"top-skills"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
     ## Skills

    <!--hvy:component-list {"id":"top-skills-list","componentListComponent":"skill-xref-card","componentListItemLabel":"skill reference","css":"margin: 0;","align":"center"}-->

     <!--hvy:component-list:0 {}-->

      <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Software Engineering","xrefDetail":"Core strength","xrefTarget":"skill-software-engineering"}-->

     <!--hvy:component-list:1 {}-->

      <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Library Development","xrefDetail":"Reusable systems","xrefTarget":"skill-library-development"}-->

     <!--hvy:component-list:2 {}-->

      <!--hvy:skill-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"LLM Prompt Engineering","xrefDetail":"Product workflow design","xrefTarget":"skill-llm-prompt-engineering"}-->

  <!--hvy:grid:1 {"id":"top-tools-technologies"}-->

   <!--hvy:container {"css":"margin: 0;","align":"center"}-->

    <!--hvy:text {"align":"center","css":"margin: 0 0 0.35rem;"}-->
     ## Tools & Technologies

    <!--hvy:component-list {"id":"top-tools-technologies-list","componentListComponent":"tool-tech-xref-card","componentListItemLabel":"tool / tech reference","css":"margin: 0;","align":"center"}-->

     <!--hvy:component-list:0 {}-->

      <!--hvy:tool-tech-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"TypeScript","xrefDetail":"Primary application language","xrefTarget":"tool-typescript"}-->

     <!--hvy:component-list:1 {}-->

      <!--hvy:tool-tech-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Python","xrefDetail":"Automation and prototyping","xrefTarget":"tool-python"}-->

     <!--hvy:component-list:2 {}-->

      <!--hvy:tool-tech-xref-card {"css":"margin: 0.35rem 0;","xrefTitle":"Developer Containers","xrefDetail":"Reproducible local environments","xrefTarget":"tool-developer-containers"}-->

<!--hvy: {"id":"skills","lock":true,"expanded":false,"location":"sidebar","description":"Skills reference list"}-->
#! Skills

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Skills

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"skill-record","componentListItemLabel":"skill","tags":"skill","componentListDefaultSortKey":"Strength","componentListDefaultSortDirection":"desc"}-->

  <!--hvy:component-list:0 {}-->

   <!--hvy:skill-record {"id":"skill-software-engineering","xrefTitle":"Software Engineering","tags":"skill","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Software Engineering","Strength":98},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Software Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing, building, and maintaining software systems with a focus on reliability, maintainability, and developer experience.
      ^detail-heading^ #### Notes
      ^detail-body^ Core strength. Approaches engineering as a systems discipline — prioritizing clear APIs, testable boundaries, and incremental delivery over clever solutions.

  <!--hvy:component-list:1 {}-->

   <!--hvy:skill-record {"id":"skill-reverse-engineering","xrefTitle":"Reverse Engineering","tags":"skill","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Reverse Engineering","Strength":87},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Reverse Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Analyzing existing systems, file formats, or tool internals to understand structure and behavior without access to original specifications.
      ^detail-heading^ #### Notes
      ^detail-body^ Applied primarily to understand undocumented formats and third-party tool internals for building compatible tooling.

  <!--hvy:component-list:2 {}-->

   <!--hvy:skill-record {"id":"skill-library-development","xrefTitle":"Library Development","tags":"skill","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Library Development","Strength":93},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Library Development

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing and maintaining reusable software packages intended for use across multiple applications or by other developers.
      ^detail-heading^ #### Notes
      ^detail-body^ Built shared TypeScript platform packages that reduced duplicated code across products and improved consistency of internal tooling.

  <!--hvy:component-list:3 {}-->

   <!--hvy:skill-record {"id":"skill-llm-prompt-engineering","xrefTitle":"LLM Prompt Engineering","tags":"skill","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"LLM Prompt Engineering","Strength":91},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### LLM Prompt Engineering

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Designing and iterating on prompts and workflows that direct large language model behavior toward reliable, useful outputs in product contexts.
      ^detail-heading^ #### Notes
      ^detail-body^ Used to design AI-assisted editor workflows and autonomous agent pipelines. Focuses on structured output, fallback handling, and iterative refinement.

  <!--hvy:component-list:4 {}-->

   <!--hvy:skill-record {"id":"skill-project-management","xrefTitle":"Project Management","tags":"skill","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Project Management","Strength":84},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Project Management

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Coordinating people, timelines, and deliverables to move work from idea to shipped with clear ownership and minimal ceremony.
      ^detail-heading^ #### Notes
      ^detail-body^ Lightweight approach — async-first communication and clear ownership over process overhead. Comfortable leading small cross-functional efforts.

<!--hvy: {"id":"tools-technologies","lock":true,"expanded":false,"location":"sidebar","description":"Tools and technologies reference list"}-->
#! Tools & Technologies

 <!--hvy:text {"css":"margin: 0.5rem 0;"}-->
  # Tools & <!--hvy:alt {"compact":"Tech"}-->Technologies<!--/hvy:alt-->

 <!--hvy:component-list {"css":"margin: 0;","componentListComponent":"tool-tech-record","componentListItemLabel":"tool / technology","tags":"tool","componentListDefaultSortKey":"Strength","componentListDefaultSortDirection":"desc","componentListDefaultGroupKey":"Category"}-->

  <!--hvy:component-list:0 {}-->

   <!--hvy:tool-tech-record {"id":"tool-typescript","xrefTitle":"TypeScript","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"TypeScript","Strength":96},"groupKeys":{"Category":"Programming Languages"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### TypeScript

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Statically typed superset of JavaScript used for large-scale web applications, tooling, and shared platform packages.
      ^detail-heading^ #### Notes
      ^detail-body^ Primary application language. Uses strict mode throughout with explicit types at API boundaries. Comfortable with both frontend and Node.js contexts.

  <!--hvy:component-list:1 {}-->

   <!--hvy:tool-tech-record {"id":"tool-python","xrefTitle":"Python","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Python","Strength":91},"groupKeys":{"Category":"Programming Languages"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Python

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ High-level dynamically typed language commonly used for scripting, automation, data processing, and AI/ML integrations.
      ^detail-heading^ #### Notes
      ^detail-body^ Used for automation scripts, prototyping, and AI API integrations. Comfortable with async patterns and CLI tooling.

  <!--hvy:component-list:2 {}-->

   <!--hvy:tool-tech-record {"id":"tool-c-cpp","xrefTitle":"C/C++","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"C/C++","Strength":72},"groupKeys":{"Category":"Programming Languages"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### C/C++

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Systems programming languages used for performance-critical software, operating systems, compilers, and graphics work.
      ^detail-heading^ #### Notes
      ^detail-body^ Background from coursework in operating systems, compilers, and computer graphics. Applied in academic projects; not a current primary language.

  <!--hvy:component-list:3 {}-->

   <!--hvy:tool-tech-record {"id":"tool-developer-containers","xrefTitle":"Developer Containers","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"Developer Containers","Strength":89},"groupKeys":{"Category":"Development Environments"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### Developer Containers

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Docker-based development environments defined as code, providing reproducible and portable local setups with all dependencies pre-configured.
      ^detail-heading^ #### Notes
      ^detail-body^ Built and maintained dev containers for multiple projects. Cut onboarding time from days to hours and ensured test parity with CI environments.

  <!--hvy:component-list:4 {}-->

   <!--hvy:tool-tech-record {"id":"tool-openai-api","xrefTitle":"OpenAI API","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"OpenAI API","Strength":86},"groupKeys":{"Category":"AI / Agent Tooling"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### OpenAI API

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ REST API providing access to OpenAI's language and embedding models for integration into applications and agent workflows.
      ^detail-heading^ #### Notes
      ^detail-body^ Used to power a deep research agent during a hackathon. Familiar with prompt construction, streaming, and managing token budgets.

  <!--hvy:component-list:5 {}-->

   <!--hvy:tool-tech-record {"id":"tool-github-codespaces","xrefTitle":"GitHub Codespaces","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"GitHub Codespaces","Strength":82},"groupKeys":{"Category":"Development Environments"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### GitHub Codespaces

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Cloud-hosted development environments that run VS Code in the browser backed by a remote container, eliminating local setup requirements.
      ^detail-heading^ #### Notes
      ^detail-body^ Used as the hosting target for the Autonomous Agent Hackathon, allowing teammates to run the agent without any local environment setup.

  <!--hvy:component-list:6 {}-->

   <!--hvy:tool-tech-record {"id":"tool-superagi","xrefTitle":"SuperAGI","tags":"tool","css":"margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);","sortKeys":{"Name":"SuperAGI","Strength":76},"groupKeys":{"Category":"AI / Agent Tooling"},"expandableAlwaysShowStub":true,"expandableExpanded":false}-->

    <!--hvy:expandable:stub {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ### SuperAGI

    <!--hvy:expandable:content {}-->

     <!--hvy:text {"css":"margin: 0;"}-->
      ^detail-heading^ #### Description
      ^detail-body^ Open-source autonomous agent framework that orchestrates multi-step AI tasks using tools, memory, and goal-driven loops.
      ^detail-heading^ #### Notes
      ^detail-body^ Core technology used in the Autonomous Agent Hackathon. Designed the agent architecture and wrote all integration code connecting it to the research task pipeline.

