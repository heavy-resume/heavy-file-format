---
hvy_version: 0.1
template: true
title: Resume Template
reader_max_width: 60rem
ai-context: >-
  This is a resume template. Use the top-skills-tools-technologies section for featured
  xref-card links only; the skills and tools-technologies sidebar sections are the main
  reusable libraries for detailed skill/tool records. History, projects, and education
  each have a summary table followed by a component-list of expandable records; keep
  both in reverse chronological order with newest entries first. One organization,
  project, degree, skill, or tool should usually be represented as one expandable
  reusable record. Local skills/tools lists inside history, project, and education records
  are supporting xrefs and should not be treated as the main libraries.
section_defaults:
  css: "margin: 0.5rem 0;"
theme:
  colors:
    --hvy-bg: "#f5f9ff"
    --hvy-bg-alt: "#eef3fa"
    --hvy-surface: "#ffffff"
    --hvy-surface-alt: "#f9fcff"
    --hvy-surface-tint: "#d9eaf4"
    --hvy-text: "#1a2530"
    --hvy-text-alt: "#4b5c67"
    --hvy-text-muted: "#6b8fa0"
    --hvy-accent-1: "#2c5e78"
    --hvy-accent-1-alt: "#1f4f63"
    --hvy-accent-1-text: "#000000"
    --hvy-accent-2: "#325f6e"
    --hvy-accent-2-alt: "#244355"
    --hvy-button-bg: "#4a8fab"
    --hvy-button-text: "#000000"
    --hvy-link-color: "#162f3d"
    --hvy-highlight-1: "rgba(31, 122, 140, 0.15)"
    --hvy-highlight-2: "rgba(255, 214, 102, 0.35)"
    --hvy-border: "#ced9e2"
    --hvy-border-alt: "#b8c8d3"
    --hvy-border-input: "#c8d4dd"
    --hvy-border-translucent: "rgba(206, 217, 226, 0.92)"
    --hvy-xref-card-bg: "#f3f5f8"
    --hvy-xref-card-hover-bg: "#eef8fb"
    --hvy-table-header: "#e5e7eb"
    --hvy-table-row-bg-1: "#ffffff"
    --hvy-table-row-bg-2: "#f9fafb"
    --hvy-icon-muted: "rgba(26, 37, 48, 0.33)"
    --hvy-shadow: "rgba(39, 70, 91, 0.08)"
    --hvy-shadow-md: "rgba(39, 70, 91, 0.12)"
    --hvy-shadow-lg: "rgba(39, 70, 91, 0.14)"
    --hvy-overlay: "rgba(15, 23, 32, 0.4)"
    --hvy-danger: "#a64040"
    --hvy-warning: "#c79200"
    --hvy-warning-bg: "#fff3de"
    --hvy-warning-border: "#ebca8d"
    --hvy-warning-text: "#e2b100"
    --hvy-success: "#1c6231"
    --hvy-success-bg: "#e7f9ee"
    --hvy-success-border: "#95d8a9"
component_defs:
  - name: history-record
    baseType: expandable
    description: One expandable work-history role at a single organization; stub table summarizes year, organization, and title, while expanded content holds location, date range, title, description, accomplishments, and supporting skill/tool xrefs.
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;"
              tableColumns: "YEAR, ORGANIZATION, TITLE"
              tableShowHeader: false
              tableRows:
                - cells: ["", "", ""]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: text
              placeholder: Organization
              css: "margin: 0 0 0.35rem;"
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: history-location
                  block:
                    text: ""
                    schema:
                      component: text
                      placeholder: location
                      css: "margin: 0;"
                - id: history-date-range
                  block:
                    text: ""
                    schema:
                      component: text
                      placeholder: date range
                      css: "margin: 0; text-align: right;"
          - text: ""
            schema:
              component: text
              placeholder: job title
              css: "margin: 0.35rem 0; font-weight: 700;"
          - text: ""
            schema:
              component: text
              placeholder: description
              css: "margin: 0.35rem 0;"
          - text: "#### Accomplishments"
            schema:
              component: text
              css: "margin: 0.5rem 0 0.25rem;"
          - text: ""
            schema:
              component: component-list
              componentListComponent: text
              componentListItemLabel: accomplishment
              css: "margin: 0;"
              componentListBlocks: []
          - component: skills-and-tools-tech-list
  - name: skills-and-tools-tech-list
    baseType: grid
    description: "Two-column supporting xref grid: left column links to skill records, right column links to tool/technology records. Use inside history, project, and education records; do not store canonical skill/tool details here."
    schema:
      css: "margin: 0.5rem 0 0;"
      gridColumns: 2
      gridItems:
        - id: relevant-skills
          align: center
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: xref-card
              componentListItemLabel: skill
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Relevant Skills"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
        - id: tools-technologies
          align: center
          block:
            text: ""
            schema:
              component: component-list
              componentListComponent: xref-card
              componentListItemLabel: tool / tech
              css: "margin: 0;"
              componentListBlocks:
                - text: "#### Tools and Technologies"
                  schema:
                    component: text
                    css: "margin: 0 0 0.25rem;"
  - name: education-record
    baseType: expandable
    description: One expandable education entry for a degree or program; stub table summarizes degree, institution, and location, while expanded content holds details, description, classes, and supporting skill/tool xrefs.
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;"
              tableColumns: "DEGREE, INSTITUTION, LOCATION"
              tableShowHeader: false
              tableRows:
                - cells: ["", "", ""]
      expandableContentBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0.35rem 0;"
              gridColumns: 2
              gridItems:
                - id: education-institution-details
                  block:
                    text: ""
                    schema:
                      component: container
                      css: "margin: 0;"
                      containerBlocks:
                        - text: ""
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "School / University"
                        - text: ""
                          schema:
                            component: text
                            css: "margin: 0 0 0.25rem;"
                            placeholder: "Location"
                        - text: ""
                          schema:
                            component: text
                            css: "margin: 0;"
                            placeholder: "GPA"
                - id: education-date-range
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Start Year – End Year"
          - text: ""
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Description"
          - component: skills-and-tools-tech-list
          - text: "#### Classes"
            schema:
              component: text
              css: "margin: 0.5rem 0 0.25rem;"
          - text: ""
            schema:
              component: component-list
              componentListComponent: text
              componentListItemLabel: class
              css: "margin: 0;"
              componentListBlocks: []
  - name: project-record
    baseType: expandable
    description: One expandable project entry; stub table summarizes project and date, while expanded content holds title, date range, description, link, and supporting skill/tool xrefs.
    schema:
      css: "margin: 0;"
      expandableAlwaysShowStub: true
      expandableExpanded: false
      expandableStubBlocks:
        css: "padding: 0.5rem;"
        children:
          - text: ""
            schema:
              component: table
              css: "margin: 0;"
              tableColumns: "PROJECT, DATE"
              tableShowHeader: false
              tableRows:
                - cells: ["", ""]
      expandableContentBlocks:
        children:
          - text: ""
            schema:
              component: grid
              css: "margin: 0 0 0.35rem;"
              gridColumns: 2
              gridItems:
                - id: project-title
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0;"
                      placeholder: "Project name"
                - id: project-date-range
                  block:
                    text: ""
                    schema:
                      component: text
                      css: "margin: 0; text-align: right;"
                      placeholder: "Date range"
          - text: ""
            schema:
              component: text
              css: "margin: 0.5rem 0;"
              placeholder: "Project description"
          - text: ""
            schema:
              component: text
              css: "margin: 0.35rem 0;"
              placeholder: "Project link"
          - component: skills-and-tools-tech-list
  - name: skill-record-experience-section
    baseType: container
    description: Skill/tool record subsection listing xrefs to relevant work-history records.
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Experience"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListItemLabel: history reference
            componentListBlocks: []
  - name: skill-record-education-section
    baseType: container
    description: Skill/tool record subsection listing xrefs to relevant education records.
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Education"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListItemLabel: education reference
            componentListBlocks: []
  - name: skill-record-projects-section
    baseType: container
    description: Skill/tool record subsection listing xrefs to relevant project records.
    schema:
      css: "margin: 0;"

      containerBlocks:
        - text: "#### Projects"
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: xref-card
            componentListItemLabel: project reference
            componentListBlocks: []
  - name: skill-record-section
    baseType: container
    description: "Reusable subsection pattern for a skill/tool record: heading plus repeatable detail entries."
    schema:
      css: "margin: 0;"
      containerBlocks:
        - text: ""
          schema:
            component: text
            css: "margin: 0.4rem 0 0.1rem;"
            placeholder: "#### Section title"
        - text: ""
          schema:
            component: component-list
            css: "margin: 0;"
            componentListComponent: skill-record-entry
            componentListItemLabel: detail
            componentListBlocks: []
  - name: skill-record
    baseType: expandable
    description: Canonical expandable record for one skill, tool, or technology in the main library; use xref-cards elsewhere to point at this record instead of duplicating details.
    schema:
      css: "margin: 0.35rem 0; border: 1px solid var(--hvy-border); border-radius: 4px; padding: 0.35rem 0.5rem; background: var(--hvy-surface);"
      expandableStubBlocks:
        children:
          - text: ""
            schema:
              component: text
              css: "margin: 0;"
              placeholder: "Skill name"
      expandableContentBlocks:
        lock: false
        children:
          - text: "#### Description"
            schema:
              component: text
              css: "margin: 0.4rem 0 0.1rem;"
          - text: ""
            css: "margin-left: 0.5rem;"
            schema:
              component: text
              css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
              placeholder: "What is it?"
          - text: "#### Notes"
            schema:
              component: text
              css: "margin: 0.4rem 0 0.1rem;"
          - text: ""
            schema:
              component: text
              css: "margin: 0 0 0.35rem; margin-left: 0.5rem;"
              placeholder: "Notes"
          - component: skill-record-experience-section
          - component: skill-record-education-section
          - component: skill-record-projects-section
---

<!--hvy: {"id":"header","lock":true,"contained":false,"description":"Resume header with name, title, contact links, and top-level identity details."}-->
