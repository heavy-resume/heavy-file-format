{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "HVY: Start Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    },
    {
      "name": "HVY: Open In Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "HVY: Full Stack",
      "configurations": ["HVY: Start Dev Server", "HVY: Open In Chrome"],
      "stopAll": true
    }
  ]
}
